      TRUE ~ NA_character_
    ),
    sex_label = factor(sex_label, levels = c("Female", "Male")),
    
    # --- Recipient race/ethnicity ---
    race_label = case_when(
      ETHCAT == 1 ~ "White",
      ETHCAT == 2 ~ "Black/African American",
      ETHCAT == 4 ~ "Hispanic/Latino",
      ETHCAT == 5 ~ "Asian",
      ETHCAT %in% c(6, 7, 9) ~ "Other",
      ETHCAT == 998 ~ NA_character_,
      TRUE ~ NA_character_
    ),
    race_label = factor(race_label,
                        levels = c("Asian", "Black/African American", "Hispanic/Latino", "White", "Other")),
    
    # --- Diabetes ---
    diab_label = case_when(
      DIAB == 1 ~ "No",
      DIAB %in% c(2, 3, 4, 5) ~ "Yes",
