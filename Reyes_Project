      DGN_TCR %in% c(4220, 4230, 4231, 4235, 4240, 4241, 4242, 4245,
                     4250, 4255, 4260, 4264, 4265, 4290) ~ "Cholestatic liver disease",
      DGN_TCR %in% c(4280, 4285) ~ "Congenital",
      DGN_TCR %in% c(4400, 4401, 4402, 4403, 4404, 4405,
                     4410, 4420, 4430) ~ "Malignant neoplasm",
      DGN_TCR %in% c(4300, 4301, 4302, 4303, 4304, 4305,
                     4306, 4307, 4308, 4315) ~ "Metabolic disease",
      DGN_TCR %in% c(4200, 4201, 4202, 4203, 4204, 4205, 4206, 4207,
