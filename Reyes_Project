    HLAMIS        = as.numeric(HLAMIS),
    cold_isch_hr  = as.numeric(COLD_ISCH_KI),
    # WARM_ISCH_TM_DON dropped -- confirmed 0% non-missing for this cohort
    htn_don_label = case_when(
      toupper(trimws(as.character(HIST_HYPERTENS_DON))) == "Y" ~ "Yes",
      toupper(trimws(as.character(HIST_HYPERTENS_DON))) == "N" ~ "No",
