# Reading data (adjust path and file type as needed)
#---------------------------------------------------------
# Mac loading
# ----------Function: read a SAS file and return it as an array ---------------
# sas_to_array()
#   file_path : path to a .sas7bdat file
#   verbose   : if TRUE, prints dimensions/structure info (default FALSE)
# Returns: a matrix/array (Option A - as.matrix of the full data as-is)
sas_to_array <- function(file_path, verbose = FALSE, cols = NULL) {
  
  if (!file.exists(file_path)) {
    stop("File not found: ", file_path)
  }
  
  sas_data <- if (!is.null(cols)) {
    read_sas(file_path, col_select = all_of(cols))
  } else {
    read_sas(file_path)
  }
  
  sas_data <- as.data.frame(sas_data)
  
  if (verbose) {
    cat("File:", file_path, "\n")
    cat("  Dimensions:", paste(dim(sas_data), collapse = " x "), "\n")
  }
  
  return(sas_data)
}

