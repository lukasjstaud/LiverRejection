      HIST_DIABETES_DON == 998 ~ NA_character_,
      TRUE ~ NA_character_
    ),
    diab_don_label = factor(diab_don_label, levels = c("No", "Yes")),
    LDRI_cat = case_when(
      LDRI <= 1.1 ~ "LDRI \u2264 1.1",
