      DGN_TCR_KIDNEY %in% c(999, 3013, 3014, 3015, 3016, 3017, 3037, 3057) ~ "Other",
      TRUE ~ NA_character_
    ),
    esrd_etiology = factor(esrd_etiology, levels = c(
