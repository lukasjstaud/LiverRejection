#===============================================================================
# LDRI (Liver Donor Risk Index) Calculation — Feng et al. 2006, Am J Transplant 6:783-790
#===============================================================================

# Step 1: Ensure only donors with complete data across all 8 LDRI components are included
# (fixing the inverted filter logic flagged earlier — this KEEPS complete rows, not blank ones)
df_liver_ldri_complete <- df_filterEC_liver_main |>
  filter(if_all(all_of(LDRI_VAL_COL), ~ !is.na(.) & trimws(as.character(.)) != ""))

nrow(df_filterEC_liver_main) - nrow(df_liver_ldri_complete)  # how many donors got dropped for missing data

# ------------------------------------------------------------------------------
# BEFORE running the calc below, confirm your actual code values against the
# data dictionary. Run these and compare to the assumptions in the mutate() below:
table(df_liver_ldri_complete$ETHCAT_DON, useNA = "always")
table(df_liver_ldri_complete$COD_CAD_DON, useNA = "always")
table(df_liver_ldri_complete$SHARE_TY, useNA = "always")
table(df_liver_ldri_complete$LITYP, useNA = "always")
table(df_liver_ldri_complete$NON_HRT_DON, useNA = "always")
# ------------------------------------------------------------------------------

df_ldri_scored <- df_liver_ldri_complete |>
  mutate(
    AGE_DON = as.numeric(AGE_DON),
    HGT_CM_DON_CALC = as.numeric(HGT_CM_DON_CALC),
    COLD_ISCH = as.numeric(COLD_ISCH),
    
    # --- Age component (reference: age < 40) ---
    age_component = case_when(
      AGE_DON >= 40 & AGE_DON < 50 ~ 0.154,
      AGE_DON >= 50 & AGE_DON < 60 ~ 0.274,
      AGE_DON >= 60 & AGE_DON < 70 ~ 0.424,
      AGE_DON >= 70 ~ 0.501,
      TRUE ~ 0
    ),
    
    # --- Cause of death component (reference: trauma) ---
    # ASSUMED OPTN coding: 1 = Anoxia, 2 = CVA/Stroke, 3 = Head Trauma, 4 = CNS Tumor, 999 = Other
    # VERIFY against your data dictionary before trusting this.
    cod_component = case_when(
      COD_CAD_DON == 1 ~ 0.079,   # Anoxia
      COD_CAD_DON == 2 ~ 0.145,   # CVA/Stroke
      COD_CAD_DON == 3 ~ 0,       # Trauma (reference)
      TRUE ~ 0.184                # Everything else (CNS tumor, other, unmapped) -> "Other"
    ),
    
    # --- Race component (reference: White) ---
    # ASSUMED OPTN coding: 1 = White, 2 = Black/African American, else = other race
    # VERIFY against your data dictionary before trusting this.
    race_component = case_when(
      ETHCAT_DON == 1 ~ 0,        # White (reference)
      ETHCAT_DON == 2 ~ 0.176,    # African American
      TRUE ~ 0.126                # Other race
    ),
    
    # --- DCD component ---
    dcd_component = if_else(toupper(trimws(as.character(NON_HRT_DON))) == "Y", 0.411, 0),
    
    # --- Partial/split graft component ---
    # ASSUMED: LITYP == 1 is "Whole" (reference); anything else is partial/split.
    split_component = case_when(
      LITYP == 0 ~ 0,                 # Whole liver (reference)
      LITYP %in% 1:21 ~ 0.422,        # Any partial/split/reduced configuration
      TRUE ~ NA_real_                 # Safety net for any undocumented/unexpected code
    ),
    
    # --- Height component (per Feng formula, in cm) ---
    height_component = 0.066 * ((170 - HGT_CM_DON_CALC) / 10),
    
    # --- Organ sharing component (reference: local) ---
    # ASSUMED OPTN coding: 3 = Local, 4 = Regional, 5 = National
    # VERIFY against your data dictionary before trusting this.
    share_component = case_when(
      SHARE_TY == 3 ~ 0,          # Local (reference)
      SHARE_TY == 4 ~ 0.105,      # Regional
      SHARE_TY == 5 ~ 0.244,      # National
      TRUE ~ 0
    ),
    
    # --- Cold ischemia time component (hours) ---
    cit_component = 0.010 * COLD_ISCH,
    
    # --- Final LDRI ---
    LDRI = exp(
      age_component + cod_component + race_component + dcd_component +
        split_component + height_component + share_component + cit_component
    )
  )

# Pull just what you need downstream
df_ldri_final <- df_ldri_scored |>
