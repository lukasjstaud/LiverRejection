      LDRI > 1.6 ~ "LDRI > 1.6"
    ),
    LDRI_cat = factor(LDRI_cat,
                      levels = c("LDRI \u2264 1.1", "1.1 < LDRI \u2264 1.6", "LDRI > 1.6")),
    esrd_etiology = case_when(
      DGN_TCR_KIDNEY %in% c(3025, 3036, 3052, 3061, 3065) ~ "Congenital",
      DGN_TCR_KIDNEY %in% c(3011, 3012, 3038, 3039, 3069, 3070, 3071) ~ "Diabetes",
      DGN_TCR_KIDNEY %in% c(3000, 3001, 3002, 3003, 3004, 3005, 3006, 3009, 3018,
                            3033, 3035, 3041, 3042, 3043, 3054, 3055, 3067, 3068,
                            3074) ~ "Glomerular disease",
      DGN_TCR_KIDNEY %in% c(3034, 3040, 3051) ~ "Hypertensive nephrosclerosis",
      DGN_TCR_KIDNEY %in% c(3020, 3021, 3022, 3023, 3058) ~ "Neoplasm",
      DGN_TCR_KIDNEY %in% c(3008, 3028) ~ "Polycystic kidney disease",
      DGN_TCR_KIDNEY %in% c(3050, 3056, 3059, 3060, 3066) ~ "Renovascular related disease",
      DGN_TCR_KIDNEY %in% c(3007, 3010, 3024, 3026, 3027, 3029, 3030, 3031, 3032,
                            3044, 3045, 3046, 3047, 3048, 3049, 3053, 3062, 3063,
