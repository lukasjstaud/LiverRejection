  mutate(donor_type_cat = factor(donor_type_cat,
                                 levels = c("LD-KALT", "KDPI <20", "KDPI 20-85", "KDPI >85")))

df_kalt_only |> count(donor_type_cat)  # final check -- compare to 313 / 107 / 624 / 71

table3 <- df_kalt_only |>
  tbl_summary(
    by = donor_type_cat,
    type = list(HLAMIS ~ "continuous"),  # force continuous -- low cardinality (0-6) trips gtsummary's default
    statistic = list(
      all_continuous()  ~ "{mean} ({sd})",
      all_categorical() ~ "{n} ({p}%)"
    ),
    digits = all_continuous() ~ 1,
    label = list(
      AGE                ~ "Age, mean (SD), y",
      sex_label          ~ "Sex, n (%)",
      BMI_CALC           ~ "BMI, mean (SD), kg/m\u00b2",
      race_label         ~ "Race/ethnicity, n (%)",
      htn_don_label      ~ "History of hypertension, n (%)",
      diab_don_label     ~ "History of diabetes, n (%)",
      dialysis_label     ~ "Dialysis, n (%)",
      waiting_time_yrs   ~ "Waiting time, mean (SD), y",
      olt_to_kalt_yrs    ~ "Time between OLT and KALT, mean (SD), y",  # confirm vs. months -- see note above
      HLAMIS             ~ "HLA mismatch, mean (SD)",
      cold_isch_hr       ~ "Cold ischemia time, mean (SD), hr",
      LDRI_cat           ~ "Liver donor risk index, n (%)",
      esrd_etiology      ~ "Etiology of ESRD, n (%)"
