#=================================================================
# Demographic Table Functions
#-----------------------------------

# Claude simplification of my manual calculation
# ------------------------------------------------------------------------
# Function 1: raw counts and medians
# ------------------------------------------------------------------------
calc_demo_stats <- function(df) {
  n_total <- nrow(df)
  
  race_wt    <- sum(df$ETHCAT == "1", na.rm = TRUE)
  race_bl    <- sum(df$ETHCAT == "2", na.rm = TRUE)
  race_his   <- sum(df$ETHCAT == "4", na.rm = TRUE)
  race_asia  <- sum(df$ETHCAT == "5", na.rm = TRUE)
  race_denom <- sum(!is.na(df$ETHCAT))
  race_other <- race_denom - sum(race_wt, race_bl, race_his, race_asia)
  
  # Diabetes: 1 = negative, 2-5 = positive, 998 = unknown, true NA = missing
  # (unknown and missing both excluded from denom)
  diab_pos <- sum(as.numeric(df$DIAB) %in% 2:5, na.rm = TRUE)
  diab_neg <- sum(as.numeric(df$DIAB) == 1, na.rm = TRUE)
  diab_denom <- diab_pos + diab_neg
  
  txkid <- sum(df$TXKID %in% c("L","R","E"), na.rm = TRUE)
  txhrt <- sum(df$TXHRT == "Y", na.rm = TRUE)
  txlng <- sum(df$TXLNG %in% c("L","R","E"), na.rm = TRUE)
  txpan <- sum(df$TXPAN %in% c("L","R","E"), na.rm = TRUE)
  # organ-transplanted denominator: patients with non-NA info in ANY of the organ columns
  organ_denom <- sum(!is.na(df$TXKID) | !is.na(df$TXHRT) | !is.na(df$TXLNG) | !is.na(df$TXPAN))
  txliv <- organ_denom - sum(txkid, txhrt, txlng, txpan)
  
  list(
    n            = n_total,
    
    age_med      = median(df$AGE, na.rm = TRUE),
    age_q1       = quantile(df$AGE, 0.25, na.rm = TRUE),
    age_q3       = quantile(df$AGE, 0.75, na.rm = TRUE),
    
    gen_count    = sum(df$GENDER == "M", na.rm = TRUE),
    gen_denom    = sum(!is.na(df$GENDER)),
    
    race_wt      = race_wt,
    race_bl      = race_bl,
    race_his     = race_his,
    race_asia    = race_asia,
    race_other   = race_other,
    race_denom   = race_denom,
    
    diab_pos     = diab_pos,
    diab_denom   = diab_denom,
    
    meld_med     = median(df$MELD_PELD_LAB_SCORE, na.rm = TRUE),
    meld_q1      = quantile(df$MELD_PELD_LAB_SCORE, 0.25, na.rm = TRUE),
    meld_q3      = quantile(df$MELD_PELD_LAB_SCORE, 0.75, na.rm = TRUE),
    
    txliv        = txliv,
    txkid        = txkid,
    txhrt        = txhrt,
    txlng        = txlng,
    txpan        = txpan,
    organ_denom  = organ_denom,
    
    liv_don      = sum(df$DON_TY == "L", na.rm = TRUE),
    liv_don_denom= sum(!is.na(df$DON_TY)),
    
    cold_isch_med= median(df$COLD_ISCH, na.rm = TRUE),
    cold_isch_q1 = quantile(df$COLD_ISCH, 0.25, na.rm = TRUE),
    cold_isch_q3 = quantile(df$COLD_ISCH, 0.75, na.rm = TRUE),
    
    prev_liver   = sum(df$PREV_TX == "Y", na.rm = TRUE),
    prev_liver_denom = sum(!is.na(df$PREV_TX)),
    
    prev_tx_0    = sum(is.na(df$PREV_TX_ANY_N)),   # NA here IS meaningful (= 0 prior tx), kept as-is
    prev_tx_1    = sum(df$PREV_TX_ANY_N == "1", na.rm = TRUE),
    prev_tx_2    = sum(df$PREV_TX_ANY_N == "2", na.rm = TRUE),
    prev_tx_3    = sum(df$PREV_TX_ANY_N == "3", na.rm = TRUE),
    
    hla_0        = sum(df$MM_TOTAL == 0, na.rm = TRUE),
    hla_1        = sum(df$MM_TOTAL == 1, na.rm = TRUE),
    hla_2        = sum(df$MM_TOTAL == 2, na.rm = TRUE),
    hla_3        = sum(df$MM_TOTAL == 3, na.rm = TRUE),
    hla_4        = sum(df$MM_TOTAL == 4, na.rm = TRUE),
    hla_5        = sum(df$MM_TOTAL == 5, na.rm = TRUE),
    hla_6        = sum(df$MM_TOTAL == 6, na.rm = TRUE),
    hla_denom    = sum(!is.na(df$MM_TOTAL)),
    
    perf_n       = sum(df$LI_MACHINE_PERFUSION == "Y", na.rm = TRUE),
    perf_denom   = sum(!is.na(df$LI_MACHINE_PERFUSION)),
    perf_typed_n = sum(!is.na(df$LI_MACHINE_PERFUSION_TY)),
    perf_normo   = sum(df$LI_MACHINE_PERFUSION_TY == "1", na.rm = TRUE),
    perf_hypo    = sum(df$LI_MACHINE_PERFUSION_TY == "2", na.rm = TRUE)
  )
}

# ------------------------------------------------------------------------
# Function 2: IQR strings + percentages, built FROM the stats list above
# (takes the output of calc_demo_stats, so no re-filtering of the df needed)
# ------------------------------------------------------------------------
calc_demo_std <- function(s) {
  # generic safe percent: returns NA instead of NaN/Inf if denom is 0
  pct <- function(count, denom) {
    if (is.na(denom) || denom == 0) return(NA_real_)
    100 * count / denom
  }
  
  list(
    age_qstring   = paste0(" (", s$age_q1, "\u2013", s$age_q3, ")"),
    
    gen_perc      = pct(s$gen_count, s$gen_denom),
    
    race_wt_perc    = pct(s$race_wt, s$race_denom),
    race_bl_perc    = pct(s$race_bl, s$race_denom),
    race_his_perc   = pct(s$race_his, s$race_denom),
    race_asia_perc  = pct(s$race_asia, s$race_denom),
    race_other_perc = pct(s$race_other, s$race_denom),
    
    diab_perc = pct(s$diab_pos, s$diab_denom),
    
    meld_qstring  = paste0(" (", s$meld_q1, "\u2013", s$meld_q3, ")"),
    
    txliv_perc    = pct(s$txliv, s$organ_denom),
    txkid_perc    = pct(s$txkid, s$organ_denom),
    txhrt_perc    = pct(s$txhrt, s$organ_denom),
    txlng_perc    = pct(s$txlng, s$organ_denom),
    txpan_perc    = pct(s$txpan, s$organ_denom),
    
    liv_don_perc  = pct(s$liv_don, s$liv_don_denom),
    
    isch_qstring  = paste0(" (", s$cold_isch_q1, "\u2013", s$cold_isch_q3, ")"),
    
    prev_liv_perc  = pct(s$prev_liver, s$prev_liver_denom),
    prev_tx_0_perc = pct(s$prev_tx_0, s$n),   # NA in PREV_TX_ANY_N counts as "0 prior", so denom stays n
    prev_tx_1_perc = pct(s$prev_tx_1, s$n),
    prev_tx_2_perc = pct(s$prev_tx_2, s$n),
    prev_tx_3_perc = pct(s$prev_tx_3, s$n),
    
    hla_0_perc = pct(s$hla_0, s$hla_denom),
    hla_1_perc = pct(s$hla_1, s$hla_denom),
    hla_2_perc = pct(s$hla_2, s$hla_denom),
    hla_3_perc = pct(s$hla_3, s$hla_denom),
    hla_4_perc = pct(s$hla_4, s$hla_denom),
    hla_5_perc = pct(s$hla_5, s$hla_denom),
    hla_6_perc = pct(s$hla_6, s$hla_denom),
    
    perf_n_perc     = pct(s$perf_n, s$perf_denom),
    perf_normo_perc = pct(s$perf_normo, s$perf_typed_n),
    perf_hypo_perc  = pct(s$perf_hypo, s$perf_typed_n)
  )
}

# ------------------------------------------------------------------------
# Assemble the mean_* and std_* vectors in demo_label1 order
# ------------------------------------------------------------------------
build_mean_vector <- function(s) {
  c(
    s$n,
    s$age_med,
    s$gen_count,
    NA,
    s$race_wt, s$race_bl, s$race_his, s$race_asia, s$race_other,
    s$diab_pos,
    s$meld_med,
    NA,
    s$txliv, s$txkid, s$txhrt, s$txlng, s$txpan,
    s$liv_don,
    s$cold_isch_med,
    s$prev_liver,
    NA,
    s$prev_tx_0, s$prev_tx_1, s$prev_tx_2, s$prev_tx_3,
    NA,                                  # HLA header
    s$hla_0, s$hla_1, s$hla_2, s$hla_3, s$hla_4, s$hla_5, s$hla_6,
    s$perf_n,                            # Liver Perfusion, n(%) — now a real count
    s$perf_normo, s$perf_hypo
  )
}

build_std_vector <- function(s, std) {
  c(
    NA,
    std$age_qstring,
    std$gen_perc,
    NA,
    std$race_wt_perc, std$race_bl_perc, std$race_his_perc, std$race_asia_perc, std$race_other_perc,
    std$diab_perc,
    std$meld_qstring,
    NA,
    std$txliv_perc, std$txkid_perc, std$txhrt_perc, std$txlng_perc, std$txpan_perc,
    std$liv_don_perc,
    std$isch_qstring,
    std$prev_liv_perc,
    NA,
    std$prev_tx_0_perc, std$prev_tx_1_perc, std$prev_tx_2_perc, std$prev_tx_3_perc,
    NA,                                  # HLA header
    std$hla_0_perc, std$hla_1_perc, std$hla_2_perc, std$hla_3_perc,
    std$hla_4_perc, std$hla_5_perc, std$hla_6_perc,
    std$perf_n_perc,                     # Liver Perfusion, n(%)
    std$perf_normo_perc, std$perf_hypo_perc
  )
}

