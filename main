std_ctrl <- data.frame(std_ctrl = build_std_vector(ctrl_stats, ctrl_std))

#------------------------------------------------------------------------
# Statistical Testing: Rejection vs Control
# ------------------------------------------------------------------------
# Continuous vars (median/IQR rows) -> Wilcoxon rank-sum test (matches your
#   nonparametric median/IQR reporting; swap for t.test() if you want means)
# Binary categorical vars (single yes/no row) -> chi-square, falling back to
#   Fisher's exact when any expected cell count is small
# Multi-level categorical vars (Race, Organ, Prev Tx count, HLA MM, Perfusion
#   type) -> ONE chi-square/Fisher test across the full contingency table,
#   reported once on the group header row (standard Table 1 convention)
#
# NOTE: test_multilevel() derives its category levels from whatever is
# actually observed in EITHER group being compared (rather than assuming
# both sides share identical categories). This avoids silently misaligning
# columns, or erroring out entirely, when one arm has zero patients in a
# given category (e.g. zero Hispanic patients in a small treatment arm,
# or zero Heart-transplant patients in a control arm).

calc_pvalues <- function(df_rej, df_ctrl) {
  
  test_cont <- function(var) {
    x <- df_rej[[var]]; y <- df_ctrl[[var]]
    if (sum(!is.na(x)) < 2 || sum(!is.na(y)) < 2) return(NA_real_)
    tryCatch(wilcox.test(x, y)$p.value, error = function(e) NA_real_)
  }
  
  test_binary <- function(var, target_val) {
    a <- sum(df_rej[[var]]  == target_val, na.rm = TRUE)
    b <- sum(!is.na(df_rej[[var]]))  - a
    c <- sum(df_ctrl[[var]] == target_val, na.rm = TRUE)
    d <- sum(!is.na(df_ctrl[[var]])) - c
    tab <- matrix(c(a, b, c, d), nrow = 2)
    if (sum(tab) == 0) return(NA_real_)
    tryCatch(
      if (any(tab < 5)) fisher.test(tab)$p.value else chisq.test(tab)$p.value,
      error = function(e) NA_real_
    )
  }
  
  test_multilevel <- function(x, y) {
    lv <- sort(unique(c(as.character(x), as.character(y))))
    x <- factor(as.character(x), levels = lv)
    y <- factor(as.character(y), levels = lv)
    tab <- rbind(table(x), table(y))
    if (any(rowSums(tab) == 0) || any(colSums(tab) == 0)) return(NA_real_)
    tryCatch(
      if (any(tab < 5)) {
        fisher.test(tab, simulate.p.value = ncol(tab) > 2)$p.value
      } else {
        chisq.test(tab)$p.value
      },
      error = function(e) NA_real_
    )
  }
  
  # --- Race groups (mirrors calc_demo_stats bucketing) ---
  race_group <- function(df) {
    case_when(
      df$ETHCAT == "1" ~ "White",
      df$ETHCAT == "2" ~ "Black",
      df$ETHCAT == "4" ~ "Hispanic",
      df$ETHCAT == "5" ~ "Asian",
      !is.na(df$ETHCAT) ~ "Other",
      TRUE ~ NA_character_
    )
  }
  
  test_diab <- function(df_rej, df_ctrl) {
    pos_rej <- sum(as.numeric(df_rej$DIAB) %in% 2:5, na.rm = TRUE)
    neg_rej <- sum(as.numeric(df_rej$DIAB) == 1, na.rm = TRUE)
    
    pos_ctrl <- sum(as.numeric(df_ctrl$DIAB) %in% 2:5, na.rm = TRUE)
    neg_ctrl <- sum(as.numeric(df_ctrl$DIAB) == 1, na.rm = TRUE)
    
    tab <- matrix(c(pos_rej, neg_rej, pos_ctrl, neg_ctrl), nrow = 2)
    if (sum(tab) == 0) return(NA_real_)
    tryCatch(
      if (any(tab < 5)) fisher.test(tab)$p.value else chisq.test(tab)$p.value,
      error = function(e) NA_real_
    )
  }
  
  # --- Organ transplanted groups (mirrors calc_demo_stats bucketing) ---
  organ_group <- function(df) {
    has_data <- !is.na(df$TXKID) | !is.na(df$TXHRT) | !is.na(df$TXLNG) | !is.na(df$TXPAN)
    grp <- case_when(
      df$TXKID %in% c("L","R","E") ~ "Kidney",
      df$TXHRT == "Y"              ~ "Heart",
      df$TXLNG %in% c("L","R","E") ~ "Lung",
      df$TXPAN %in% c("L","R","E") ~ "Pancreas",
      TRUE ~ "Liver only"
    )
    if_else(has_data, grp, NA_character_)
  }
  
  p_age    <- test_cont("AGE")
  p_gender <- test_binary("GENDER", "M")
  p_race   <- test_multilevel(race_group(df_rej), race_group(df_ctrl))
  p_diab   <- test_diab(df_rej, df_ctrl)
  p_meld   <- test_cont("MELD_PELD_LAB_SCORE")
  p_organ  <- test_multilevel(organ_group(df_rej), organ_group(df_ctrl))
  p_livdon <- test_binary("DON_TY", "L")
  p_isch   <- test_cont("COLD_ISCH")
  p_prev_liv <- test_binary("PREV_TX", "Y")
  p_prev_any <- test_multilevel(
    factor(replace(df_rej$PREV_TX_ANY_N, is.na(df_rej$PREV_TX_ANY_N), "0")),
    factor(replace(df_ctrl$PREV_TX_ANY_N, is.na(df_ctrl$PREV_TX_ANY_N), "0"))
  )
  p_hla    <- test_multilevel(
    factor(df_rej$MM_TOTAL,  levels = 0:6),
    factor(df_ctrl$MM_TOTAL, levels = 0:6)
  )
  p_perf_used <- test_binary("LI_MACHINE_PERFUSION", "Y")
  p_perf_ty   <- test_multilevel(
    factor(df_rej$LI_MACHINE_PERFUSION_TY,  levels = c("1","2")),
    factor(df_ctrl$LI_MACHINE_PERFUSION_TY, levels = c("1","2"))
  )
  
  # Build vector aligned to demo_label1 order. NA on rows where no single
  # test applies (headers, individual levels within a multi-level block —
  # the p-value is reported once, on the block's header row instead).
  c(
    NA,          # n
    p_age,
    p_gender,
    p_race,
    NA, NA, NA, NA, NA,
    p_diab,
    p_meld,
    p_organ,
    NA, NA, NA, NA, NA,
    p_livdon,
    p_isch,
    p_prev_liv,
    p_prev_any,
    NA, NA, NA, NA,
    p_hla,
    NA, NA, NA, NA, NA, NA, NA,
    p_perf_used,
    p_perf_ty,
    NA
  )
}

pval_rej_ctrl <- calc_pvalues(pat_combined_demo_table_m_steroid, pat_steroid_demo_table_m) # EDIT HERE for match at_combined_demo_table, pat_steroid_demo_table

# ------------------------------------------------------------------------
# Tibble Demographic Data (now including p-values)
# ------------------------------------------------------------------------
tbl_data <- tibble(
  demo_label1,
  ref_value1,
  mean_rej,
  std_rej,
  mean_ctrl,
  std_ctrl,
  pval_rej_ctrl
)

#------------------------------------------
# Demographic Table (relabeled: Combined / Steroid)
format_table2 <- function() {
  tbl_data %>%
    filter(demo_label1 != "n") %>%
    mutate(
      is_header = is.na(ref_value1) & is.na(std_rej),
      is_median = str_detect(demo_label1, "median\\(IQR\\)") |
        (!is_header & str_detect(std_rej, "^\\(")),
      mean_rej_fmt  = if_else(is_median, NA_character_,
                              format(round(mean_rej), big.mark = ",", scientific = FALSE)),
      mean_ctrl_fmt = if_else(is_median, NA_character_,
                              format(round(mean_ctrl), big.mark = ",", scientific = FALSE)),
      Combined = case_when(
        is_header ~ NA_character_,
        demo_label1 == "n" ~ mean_rej_fmt,
        is_median ~ paste0(format(mean_rej, big.mark = ","), " ", std_rej),
        TRUE ~ paste0(mean_rej_fmt,
                      " (", sprintf("%.1f", as.numeric(std_rej)), "%)")
      ),
      Steroid = case_when(
        is_header ~ NA_character_,
        demo_label1 == "n" ~ mean_ctrl_fmt,
        is_median ~ paste0(format(mean_ctrl, big.mark = ","), " ", std_ctrl),
        TRUE ~ paste0(mean_ctrl_fmt,
                      " (", sprintf("%.1f", as.numeric(std_ctrl)), "%)")
      ),
      `P value` = case_when(
        is.na(pval_rej_ctrl) ~ NA_character_,
        pval_rej_ctrl < 0.001 ~ "<0.001",
        TRUE ~ sprintf("%.3f", pval_rej_ctrl)
      ),
      Variable = if_else(is_header, demo_label1,
                         paste0("    ", demo_label1))
    ) %>%
    select(Variable, Combined, Steroid, `P value`, is_header)
}

demo_tbl2 <- format_table2()

demo_tbl2 %>%
  select(-is_header) %>%
  gt() %>%
  cols_label(
    Variable = "Characteristic",
    Combined = paste0("Combined (n = ", num_rej, ")"),
    Steroid = paste0("Steroid (n = ", num_ctrl, ")"),
    `P value` = "P value"
  ) %>%
  tab_style(
    style = cell_text(weight = "bold"),
    locations = cells_body(rows = demo_tbl2$is_header)
  ) %>%
  tab_style(
    style = cell_text(align = "left"),
    locations = cells_column_labels(columns = Variable)
  ) %>%
  cols_align(align = "center", columns = c(Combined, Steroid, `P value`)) %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold"
  ) %>%
  tab_source_note("Values are n (%) or median (IQR) as indicated. P-values from Wilcoxon rank-sum (continuous), chi-square, or Fisher's exact tests (categorical) as appropriate.")

