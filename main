#===============================================================================
# Shared helpers
#-------------------------------------------------------------------------------

# [FIX 12] Chi-square vs Fisher decided on EXPECTED cell counts, not observed.
# This version was already defined further down the script and used by the
# year-2 sections; it is moved up here so calc_pvalues() (which used the weaker
# observed-count rule, `any(tab < 5)`) can use the same logic.
safe_chisq_or_fisher <- function(tab) {
  if (any(dim(tab) < 2) || sum(tab) == 0) return(NULL)
  expected <- outer(rowSums(tab), colSums(tab)) / sum(tab)
  if (any(expected < 5)) {
    fisher.test(tab, simulate.p.value = (ncol(tab) > 2 || nrow(tab) > 2))
  } else {
    chisq.test(tab)
  }
}

# [FIX 6] Organ-transplanted grouping defined ONCE and shared between
# calc_demo_stats() and calc_pvalues(). Previously calc_demo_stats computed
#   txliv <- organ_denom - sum(txkid, txhrt, txlng, txpan)
# which double-counts multi-organ recipients (a liver-kidney-pancreas patient is
# in both txkid and txpan), under-counting txliv and letting it go negative --
# while calc_pvalues used a mutually exclusive case_when(). The table and the
# p-value were describing two different variables. Both now use this hierarchy.
#
# NOTE: UNOS CSVs frequently carry "" rather than NA for these fields, so
# has_data is effectively always TRUE and the denominator becomes the full
# cohort. That is a defensible denominator, but if you want true missingness
# excluded, run na_if(x, "") on the organ columns before calling this.
organ_group <- function(df) {
  has_data <- !is.na(df$TXKID) | !is.na(df$TXHRT) | !is.na(df$TXLNG) | !is.na(df$TXPAN)
  grp <- case_when(
    df$TXKID %in% c("L","R","E") ~ "Kidney",
    df$TXHRT == "Y"              ~ "Heart",
    df$TXLNG %in% c("L","R","E") ~ "Lung",
    df$TXPAN %in% c("L","R","E") ~ "Pancreas",
    TRUE ~ "Liver only"
  )
  if_else(has_data, grp, NA_character_)
}

# Race bucketing, also shared between stats and p-values
race_group <- function(df) {
  case_when(
    df$ETHCAT == "1" ~ "White",
    df$ETHCAT == "2" ~ "Black",
    df$ETHCAT == "4" ~ "Hispanic",
    df$ETHCAT == "5" ~ "Asian",
    !is.na(df$ETHCAT) ~ "Other",
    TRUE ~ NA_character_
  )
}

#=================================================================
# Demographic Table Functions
# ------------------------------------------------------------------------
# Function 1: raw counts and medians
# ------------------------------------------------------------------------
calc_demo_stats <- function(df) {
  n_total <- nrow(df)
  
  race_wt    <- sum(df$ETHCAT == "1", na.rm = TRUE)
  race_bl    <- sum(df$ETHCAT == "2", na.rm = TRUE)
  race_his   <- sum(df$ETHCAT == "4", na.rm = TRUE)
  race_asia  <- sum(df$ETHCAT == "5", na.rm = TRUE)
  race_denom <- sum(!is.na(df$ETHCAT))
  race_other <- race_denom - sum(race_wt, race_bl, race_his, race_asia)
  
  # Diabetes: 1 = negative, 2-5 = positive, 998 = unknown, true NA = missing
  # (unknown and missing both excluded from denom)
  diab_pos <- sum(as.numeric(df$DIAB) %in% 2:5, na.rm = TRUE)
  diab_neg <- sum(as.numeric(df$DIAB) == 1, na.rm = TRUE)
  diab_denom <- diab_pos + diab_neg
  
  # [FIX 6] mutually exclusive organ categories, matching organ_group()
  og <- organ_group(df)
  txkid       <- sum(og == "Kidney",     na.rm = TRUE)
  txhrt       <- sum(og == "Heart",      na.rm = TRUE)
  txlng       <- sum(og == "Lung",       na.rm = TRUE)
  txpan       <- sum(og == "Pancreas",   na.rm = TRUE)
  txliv       <- sum(og == "Liver only", na.rm = TRUE)
  organ_denom <- sum(!is.na(og))
  
  list(
    n            = n_total,
    
    age_med      = median(df$AGE, na.rm = TRUE),
    age_q1       = quantile(df$AGE, 0.25, na.rm = TRUE),
    age_q3       = quantile(df$AGE, 0.75, na.rm = TRUE),
    
    gen_count    = sum(df$GENDER == "M", na.rm = TRUE),
    gen_denom    = sum(!is.na(df$GENDER)),
    
    race_wt      = race_wt,
    race_bl      = race_bl,
    race_his     = race_his,
    race_asia    = race_asia,
    race_other   = race_other,
    race_denom   = race_denom,
    
    diab_pos     = diab_pos,
    diab_denom   = diab_denom,
    
    meld_med     = median(df$MELD_PELD_LAB_SCORE, na.rm = TRUE),
    meld_q1      = quantile(df$MELD_PELD_LAB_SCORE, 0.25, na.rm = TRUE),
    meld_q3      = quantile(df$MELD_PELD_LAB_SCORE, 0.75, na.rm = TRUE),
    
    txliv        = txliv,
    txkid        = txkid,
    txhrt        = txhrt,
    txlng        = txlng,
    txpan        = txpan,
    organ_denom  = organ_denom,
    
    liv_don      = sum(df$DON_TY == "L", na.rm = TRUE),
    liv_don_denom= sum(!is.na(df$DON_TY)),
    
    cold_isch_med= median(df$COLD_ISCH, na.rm = TRUE),
    cold_isch_q1 = quantile(df$COLD_ISCH, 0.25, na.rm = TRUE),
    cold_isch_q3 = quantile(df$COLD_ISCH, 0.75, na.rm = TRUE),
    
    prev_liver   = sum(df$PREV_TX == "Y", na.rm = TRUE),
    prev_liver_denom = sum(!is.na(df$PREV_TX)),
    
    prev_tx_0    = sum(is.na(df$PREV_TX_ANY_N)),   # NA here IS meaningful (= 0 prior tx), kept as-is
    prev_tx_1    = sum(df$PREV_TX_ANY_N == "1", na.rm = TRUE),
    prev_tx_2    = sum(df$PREV_TX_ANY_N == "2", na.rm = TRUE),
    prev_tx_3    = sum(df$PREV_TX_ANY_N == "3", na.rm = TRUE),
    
    hla_0        = sum(df$MM_TOTAL == 0, na.rm = TRUE),
    hla_1        = sum(df$MM_TOTAL == 1, na.rm = TRUE),
    hla_2        = sum(df$MM_TOTAL == 2, na.rm = TRUE),
    hla_3        = sum(df$MM_TOTAL == 3, na.rm = TRUE),
    hla_4        = sum(df$MM_TOTAL == 4, na.rm = TRUE),
    hla_5        = sum(df$MM_TOTAL == 5, na.rm = TRUE),
    hla_6        = sum(df$MM_TOTAL == 6, na.rm = TRUE),
    hla_denom    = sum(!is.na(df$MM_TOTAL)),
    
    perf_n       = sum(df$LI_MACHINE_PERFUSION == "Y", na.rm = TRUE),
    perf_denom   = sum(!is.na(df$LI_MACHINE_PERFUSION)),
    perf_typed_n = sum(!is.na(df$LI_MACHINE_PERFUSION_TY)),
    perf_normo   = sum(df$LI_MACHINE_PERFUSION_TY == "1", na.rm = TRUE),
    perf_hypo    = sum(df$LI_MACHINE_PERFUSION_TY == "2", na.rm = TRUE)
  )
}

# ------------------------------------------------------------------------
# Function 2: IQR strings + percentages, built FROM the stats list above
# ------------------------------------------------------------------------
calc_demo_std <- function(s) {
  # generic safe percent: returns NA instead of NaN/Inf if denom is 0
  pct <- function(count, denom) {
    if (is.na(denom) || denom == 0) return(NA_real_)
    100 * count / denom
  }
  
  list(
    age_qstring   = paste0(" (", s$age_q1, "\u2013", s$age_q3, ")"),
    
    gen_perc      = pct(s$gen_count, s$gen_denom),
    
    race_wt_perc    = pct(s$race_wt, s$race_denom),
    race_bl_perc    = pct(s$race_bl, s$race_denom),
    race_his_perc   = pct(s$race_his, s$race_denom),
    race_asia_perc  = pct(s$race_asia, s$race_denom),
    race_other_perc = pct(s$race_other, s$race_denom),
    
    diab_perc = pct(s$diab_pos, s$diab_denom),
    
    meld_qstring  = paste0(" (", s$meld_q1, "\u2013", s$meld_q3, ")"),
    
    txliv_perc    = pct(s$txliv, s$organ_denom),
    txkid_perc    = pct(s$txkid, s$organ_denom),
    txhrt_perc    = pct(s$txhrt, s$organ_denom),
    txlng_perc    = pct(s$txlng, s$organ_denom),
    txpan_perc    = pct(s$txpan, s$organ_denom),
    
    liv_don_perc  = pct(s$liv_don, s$liv_don_denom),
    
    isch_qstring  = paste0(" (", s$cold_isch_q1, "\u2013", s$cold_isch_q3, ")"),
    
    prev_liv_perc  = pct(s$prev_liver, s$prev_liver_denom),
    prev_tx_0_perc = pct(s$prev_tx_0, s$n),   # NA in PREV_TX_ANY_N counts as "0 prior", so denom stays n
    prev_tx_1_perc = pct(s$prev_tx_1, s$n),
    prev_tx_2_perc = pct(s$prev_tx_2, s$n),
    prev_tx_3_perc = pct(s$prev_tx_3, s$n),
    
    hla_0_perc = pct(s$hla_0, s$hla_denom),
    hla_1_perc = pct(s$hla_1, s$hla_denom),
    hla_2_perc = pct(s$hla_2, s$hla_denom),
    hla_3_perc = pct(s$hla_3, s$hla_denom),
    hla_4_perc = pct(s$hla_4, s$hla_denom),
    hla_5_perc = pct(s$hla_5, s$hla_denom),
    hla_6_perc = pct(s$hla_6, s$hla_denom),
    
    perf_n_perc     = pct(s$perf_n, s$perf_denom),
    perf_normo_perc = pct(s$perf_normo, s$perf_typed_n),
    perf_hypo_perc  = pct(s$perf_hypo, s$perf_typed_n)
  )
}

# ------------------------------------------------------------------------
# Assemble the mean_* and std_* vectors in demo_label1 order
# [FIX 13] an NA slot added for the new "Perfusion Type, n(%)" header row
# ------------------------------------------------------------------------
build_mean_vector <- function(s) {
  out <- c(
    s$n,
    s$age_med,
    s$gen_count,
    NA,
    s$race_wt, s$race_bl, s$race_his, s$race_asia, s$race_other,
    s$diab_pos,
    s$meld_med,
    NA,
    s$txliv, s$txkid, s$txhrt, s$txlng, s$txpan,
    s$liv_don,
    s$cold_isch_med,
    s$prev_liver,
    NA,
    s$prev_tx_0, s$prev_tx_1, s$prev_tx_2, s$prev_tx_3,
    NA,                                  # HLA header
    s$hla_0, s$hla_1, s$hla_2, s$hla_3, s$hla_4, s$hla_5, s$hla_6,
    s$perf_n,                            # Liver Perfusion, n(%)
    NA,                                  # [FIX 13] Perfusion Type header
    s$perf_normo, s$perf_hypo
  )
  stopifnot(length(out) == length(demo_label1))
  as.numeric(out)
}

# [FIX 15] returns a plain character vector, NOT a one-column data.frame.
# Wrapping this in data.frame() and then dropping it into tibble() created a
# packed df-column, which is why str_detect() / as.numeric() on std_rej were so
# fragile downstream.
build_std_vector <- function(s, std) {
  out <- c(
    NA,
    std$age_qstring,
    std$gen_perc,
    NA,
    std$race_wt_perc, std$race_bl_perc, std$race_his_perc, std$race_asia_perc, std$race_other_perc,
    std$diab_perc,
    std$meld_qstring,
    NA,
    std$txliv_perc, std$txkid_perc, std$txhrt_perc, std$txlng_perc, std$txpan_perc,
    std$liv_don_perc,
    std$isch_qstring,
    std$prev_liv_perc,
    NA,
    std$prev_tx_0_perc, std$prev_tx_1_perc, std$prev_tx_2_perc, std$prev_tx_3_perc,
    NA,                                  # HLA header
    std$hla_0_perc, std$hla_1_perc, std$hla_2_perc, std$hla_3_perc,
    std$hla_4_perc, std$hla_5_perc, std$hla_6_perc,
    std$perf_n_perc,                     # Liver Perfusion, n(%)
    NA,                                  # [FIX 13] Perfusion Type header
    std$perf_normo_perc, std$perf_hypo_perc
  )
  stopifnot(length(out) == length(demo_label1))
  as.character(out)
}

# ------------------------------------------------------------------------
# Statistical Testing Function
# ------------------------------------------------------------------------
# Continuous vars (median/IQR rows) -> Wilcoxon rank-sum test
# Binary categorical vars -> chi-square, falling back to Fisher's exact
#   [FIX 12] the fallback is now triggered by EXPECTED cell counts < 5 via
#   safe_chisq_or_fisher(), not by observed counts. The observed-count rule
#   over-triggered Fisher on large but lopsided tables and under-triggered it
#   on small balanced ones.
# Multi-level categorical vars -> ONE test across the full contingency table,
#   reported once on the group header row.

calc_pvalues <- function(df_rej, df_ctrl) {
  
  test_cont <- function(var) {
    x <- df_rej[[var]]; y <- df_ctrl[[var]]
    if (sum(!is.na(x)) < 2 || sum(!is.na(y)) < 2) return(NA_real_)
    tryCatch(wilcox.test(x, y)$p.value, error = function(e) NA_real_)
  }
  
  test_binary <- function(var, target_val) {
    a <- sum(df_rej[[var]]  == target_val, na.rm = TRUE)
    b <- sum(!is.na(df_rej[[var]]))  - a
    c <- sum(df_ctrl[[var]] == target_val, na.rm = TRUE)
    d <- sum(!is.na(df_ctrl[[var]])) - c
    tab <- matrix(c(a, b, c, d), nrow = 2)
    if (sum(tab) == 0) return(NA_real_)
    tryCatch({
      res <- safe_chisq_or_fisher(tab)   # [FIX 12]
      if (is.null(res)) NA_real_ else res$p.value
    }, error = function(e) NA_real_)
  }
  
  test_multilevel <- function(x, y) {
    # levels derived from whatever is observed in EITHER group, so an arm with
    # zero patients in a category doesn't misalign columns or error out
    lv <- sort(unique(c(as.character(x), as.character(y))))
    if (length(lv) < 2) return(NA_real_)
    x <- factor(as.character(x), levels = lv)
    y <- factor(as.character(y), levels = lv)
    tab <- rbind(table(x), table(y))
    if (any(rowSums(tab) == 0) || any(colSums(tab) == 0)) return(NA_real_)
    tryCatch({
      res <- safe_chisq_or_fisher(tab)   # [FIX 12]
      if (is.null(res)) NA_real_ else res$p.value
    }, error = function(e) NA_real_)
  }
  
  test_diab <- function(df_rej, df_ctrl) {
    pos_rej <- sum(as.numeric(df_rej$DIAB) %in% 2:5, na.rm = TRUE)
    neg_rej <- sum(as.numeric(df_rej$DIAB) == 1, na.rm = TRUE)
    
    pos_ctrl <- sum(as.numeric(df_ctrl$DIAB) %in% 2:5, na.rm = TRUE)
    neg_ctrl <- sum(as.numeric(df_ctrl$DIAB) == 1, na.rm = TRUE)
    
    tab <- matrix(c(pos_rej, neg_rej, pos_ctrl, neg_ctrl), nrow = 2)
    if (sum(tab) == 0) return(NA_real_)
    tryCatch({
      res <- safe_chisq_or_fisher(tab)   # [FIX 12]
      if (is.null(res)) NA_real_ else res$p.value
    }, error = function(e) NA_real_)
  }
  
  p_age    <- test_cont("AGE")
  p_gender <- test_binary("GENDER", "M")
  p_race   <- test_multilevel(race_group(df_rej), race_group(df_ctrl))
  p_diab   <- test_diab(df_rej, df_ctrl)
  p_meld   <- test_cont("MELD_PELD_LAB_SCORE")
  p_organ  <- test_multilevel(organ_group(df_rej), organ_group(df_ctrl))   # [FIX 6] shared helper
  p_livdon <- test_binary("DON_TY", "L")
  p_isch   <- test_cont("COLD_ISCH")
  p_prev_liv <- test_binary("PREV_TX", "Y")
  p_prev_any <- test_multilevel(
    factor(replace(df_rej$PREV_TX_ANY_N, is.na(df_rej$PREV_TX_ANY_N), "0")),
    factor(replace(df_ctrl$PREV_TX_ANY_N, is.na(df_ctrl$PREV_TX_ANY_N), "0"))
  )
  p_hla    <- test_multilevel(
    factor(df_rej$MM_TOTAL,  levels = 0:6),
    factor(df_ctrl$MM_TOTAL, levels = 0:6)
  )
  p_perf_used <- test_binary("LI_MACHINE_PERFUSION", "Y")
  p_perf_ty   <- test_multilevel(
    factor(df_rej$LI_MACHINE_PERFUSION_TY,  levels = c("1","2")),
    factor(df_ctrl$LI_MACHINE_PERFUSION_TY, levels = c("1","2"))
  )
  
  # Build vector aligned to demo_label1 order.
  # [FIX 13] p_perf_ty now sits on the "Perfusion Type, n(%)" header row rather
  # than on "Normothermic".
  out <- c(
    NA,          # n
    p_age,
    p_gender,
    p_race,
    NA, NA, NA, NA, NA,
    p_diab,
    p_meld,
    p_organ,
    NA, NA, NA, NA, NA,
    p_livdon,
    p_isch,
    p_prev_liv,
    p_prev_any,
    NA, NA, NA, NA,
    p_hla,
    NA, NA, NA, NA, NA, NA, NA,
    p_perf_used,
    p_perf_ty,          # Perfusion Type header
    NA, NA              # Normothermic, Hypothermic
  )
  stopifnot(length(out) == length(demo_label1))
  as.numeric(out)
}

# ------------------------------------------------------------------------
# [FIX 14] Shared count formatter.
# format(x, big.mark = ",") inside mutate() sees the whole column and right-pads
# every element to the width of the widest one, so a count of 22 rendered as
# "   22 (4.1%)". trim = TRUE suppresses the padding.
# ------------------------------------------------------------------------
fmt_count <- function(x) {
  format(round(x), big.mark = ",", scientific = FALSE, trim = TRUE)
}

# [FIX 1] Median-row detection. The old regex "^\\(" never matched because the
# IQR strings are built with a LEADING SPACE -- paste0(" (", q1, ...). It was
# harmless only because the median\\(IQR\\) label check caught all three rows
# anyway. Fixed rather than deleted so it works if a median row is ever added
# without "median(IQR)" in its label.
is_median_row <- function(label, std) {
  str_detect(label, "median\\(IQR\\)") | (!is.na(std) & str_detect(std, "^\\s*\\("))
}

# ------------------------------------------------------------------------
# Running Demographic Functions
# ------------------------------------------------------------------------
rej_stats  <- calc_demo_stats(pat_rej_demo_table)
ctrl_stats <- calc_demo_stats(pat_ctrl_demo_table)
ritux_stats <- calc_demo_stats(pat_ritux_demo_table)

rej_std  <- calc_demo_std(rej_stats)
ctrl_std <- calc_demo_std(ctrl_stats)
ritux_std <- calc_demo_std(ritux_stats)

num_rej  <- rej_stats$n
num_ctrl <- ctrl_stats$n
num_ritux <- ritux_stats$n

mean_rej  <- build_mean_vector(rej_stats)
mean_ctrl <- build_mean_vector(ctrl_stats)
mean_ritux <- build_mean_vector(ritux_stats)

# [FIX 15] plain vectors, no data.frame() wrapper
std_rej   <- build_std_vector(rej_stats, rej_std)
std_ctrl  <- build_std_vector(ctrl_stats, ctrl_std)
std_ritux <- build_std_vector(ritux_stats, ritux_std)

# ------------------------------------------------------------------------
# Tibble Demographic Data 

tbl_data <- tibble(
  demo_label1,
  ref_value1,
  is_header_flag = header_rows,     # [FIX 1]
  mean_rej,
  std_rej,
  mean_ctrl,
  std_ctrl,
  mean_ritux,
  std_ritux
)

