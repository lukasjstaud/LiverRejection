# Graphing
#-----------
# Prepping Table for graphing
#------------------------

freq_long <- freq_drug_fol_antirej_indiv %>%
  pivot_longer(
    cols = c(rej6m_count, rej1y_count),
    names_to = "rej_period",
    values_to = "rej_count"
  ) %>%
  mutate(
    rej_period = recode(rej_period,
                        "rej6m_count" = "6-Month",
                        "rej1y_count" = "1-Year")
  )

