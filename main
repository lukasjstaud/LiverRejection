#===============================================================================
# Building a Graph of Meds rx'd with Steroids in Antirejection Therapy
#-------------------------------------------------------------------------------
dual_therapy_array <- pat_rej_array |> 
  filter(TRR_ID_CODE %in% dual_therapy_id_vect)

dual_therapy_array |>
  summarise(across(c(THYMOGLOBULIN_ANTIREJ, RITUXAN_ANTIREJ, ATGAM_ANTIREJ, SIMULECT_ANTIREJ), ~ sum(.x > 0, na.rm = TRUE)))

med_cols <- c("THYMOGLOBULIN_ANTIREJ", "RITUXAN_ANTIREJ", "ATGAM_ANTIREJ", "SIMULECT_ANTIREJ")

pivot_table <- dual_therapy_array %>%
  summarise(across(all_of(med_cols), ~ sum(.x > 0, na.rm = TRUE))) %>%
  pivot_longer(everything(), names_to = "Medication", values_to = "Frequency") %>%
  arrange(desc(Frequency))

pivot_table <- pivot_table %>%
  mutate(Percent = Frequency / sum(Frequency))

ggplot(pivot_table, aes(x = reorder(Medication, Frequency), y = Frequency)) +
  geom_col(fill = "steelblue") +
  geom_text(
    aes(label = paste0(Frequency, " (", percent(Percent, accuracy = 0.1), ")")),
    hjust = -0.1,
    size = 3.5
  ) +
  coord_flip() +
  labs(
    title = "Frequency of Combination Anti-Rejection Rx with Steroids",
    x = "Secondary Medication",
    y = "Frequency"
  ) +
  theme_minimal() +
  scale_y_continuous(expand = expansion(mult = c(0, 0.15)))

