covariates_yr2 <- df_liver_data_filtered %>%
  select(TRR_ID_CODE, AGE, GENDER, MELD_PELD_LAB_SCORE, COLD_ISCH, DIAB) %>%
  mutate(
    DIAB_BIN = case_when(
      as.numeric(DIAB) %in% 2:5 ~ 1,
      as.numeric(DIAB) == 1     ~ 0,
      TRUE                      ~ NA_real_
    ),
    GENDER = factor(GENDER)
  ) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE) %>%              # [FIX 7]
  left_join(df_hla_calc %>% select(TRR_ID_CODE, MM_TOTAL), by = "TRR_ID_CODE")

df_yr2_model <- df_yr2_by_group %>%
  left_join(covariates_yr2, by = "TRR_ID_CODE") %>%
  mutate(FIRST_YEAR_GROUP = relevel(FIRST_YEAR_GROUP, ref = "Control"))  # Control as reference

stopifnot(nrow(df_yr2_model) == nrow(df_yr2_by_group))     # [FIX 7]

tidy_glm_or <- function(fit) {
  co  <- summary(fit)$coefficients
  ci  <- suppressMessages(confint.default(fit))  # Wald CIs
  
  tibble(
    term     = rownames(co),
    OR       = exp(co[, "Estimate"]),
    CI_lower = exp(ci[, 1]),
    CI_upper = exp(ci[, 2]),
    p_value  = co[, "Pr(>|z|)"]
  ) %>%
    filter(term != "(Intercept)")
}

fit_unadj <- glm(ANY_ANTI_REJ_YR2 ~ FIRST_YEAR_GROUP, data = df_yr2_model, family = binomial)
summary(fit_unadj)

fit_null <- glm(ANY_ANTI_REJ_YR2 ~ 1, data = df_yr2_model, family = binomial)
anova(fit_null, fit_unadj, test = "LRT")

or_unadj <- tidy_glm_or(fit_unadj) %>%
  mutate(Model = "Unadjusted")

fit_adj <- glm(
  ANY_ANTI_REJ_YR2 ~ FIRST_YEAR_GROUP + AGE + GENDER + MELD_PELD_LAB_SCORE + COLD_ISCH + DIAB_BIN + MM_TOTAL,
  data = df_yr2_model,
  family = binomial
)
summary(fit_adj)

or_adj <- tidy_glm_or(fit_adj) %>%
  filter(str_detect(term, "^FIRST_YEAR_GROUP")) %>%
  mutate(Model = "Adjusted")

df_yr2_model_steroid_ref <- df_yr2_model %>%
  mutate(FIRST_YEAR_GROUP = relevel(FIRST_YEAR_GROUP, ref = "Steroid"))

fit_unadj_steroid_ref <- glm(ANY_ANTI_REJ_YR2 ~ FIRST_YEAR_GROUP, data = df_yr2_model_steroid_ref, family = binomial)
fit_adj_steroid_ref <- glm(
  ANY_ANTI_REJ_YR2 ~ FIRST_YEAR_GROUP + AGE + GENDER + MELD_PELD_LAB_SCORE + COLD_ISCH + DIAB_BIN + MM_TOTAL,
  data = df_yr2_model_steroid_ref,
  family = binomial
)

or_unadj_combined_vs_steroid <- tidy_glm_or(fit_unadj_steroid_ref) %>%
  filter(term == "FIRST_YEAR_GROUPCombined") %>%
  mutate(term = "FIRST_YEAR_GROUPCombined (ref = Steroid)", Model = "Unadjusted")

or_adj_combined_vs_steroid <- tidy_glm_or(fit_adj_steroid_ref) %>%
  filter(term == "FIRST_YEAR_GROUPCombined") %>%
  mutate(term = "FIRST_YEAR_GROUPCombined (ref = Steroid)", Model = "Adjusted")

or_results_yr2 <- bind_rows(or_unadj, or_adj, or_unadj_combined_vs_steroid, or_adj_combined_vs_steroid) %>%
  mutate(
    Comparison = case_when(
      term == "FIRST_YEAR_GROUPSteroid"                    ~ "Steroid vs Control",
      term == "FIRST_YEAR_GROUPCombined"                    ~ "Combined vs Control",
      term == "FIRST_YEAR_GROUPCombined (ref = Steroid)"    ~ "Combined vs Steroid",
      TRUE ~ term
    )
  ) %>%
  select(Comparison, Model, OR, CI_lower, CI_upper, p_value)

or_results_yr2

or_table_yr2 <- or_results_yr2 %>%
  mutate(
    `OR (95% CI)` = sprintf("%.2f (%.2f\u2013%.2f)", OR, CI_lower, CI_upper),
    `P value` = case_when(
      p_value < 0.001 ~ "<0.001",
      TRUE ~ sprintf("%.3f", p_value)
    )
  ) %>%
  select(Comparison, Model, `OR (95% CI)`, `P value`) %>%
  arrange(Comparison, Model)

or_table_yr2 %>%
  gt(groupname_col = "Comparison") %>%
  cols_label(
    Model         = "Model",
    `OR (95% CI)`= "Odds Ratio (95% CI)",
    `P value`    = "P value"
  ) %>%
  tab_header(title = "Odds of Anti-Rejection Treatment in Year 2, by First-Year Treatment Group") %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold",
    row_group.font.weight = "bold"
  ) %>%
  tab_source_note("OR > 1 indicates higher odds of being treated for rejection in year 2 relative to the comparison group. Adjusted model controls for recipient age, gender, MELD score, cold ischemic time, diabetes status, and HLA mismatch level (MM_TOTAL). Landmark cohort restricted to patients followed through 1 year (PTIME >= 365.25).")

