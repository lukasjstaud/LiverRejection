# Mac loading
df_immuno_fol_read <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver_immuno_followup.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_liver_data <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver_data.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_immuno_induc <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver-immuno-discharge_unfilter.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_hla <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver_addtl_hla.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_pra <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver_pra_crossmatch_data.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_deceased_don <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/deceased_donor_data.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
df_liver_fol <- read.csv("~/Local Documents/AOT/Analysis/FilteredData/liver_followup_data.csv", stringsAsFactors = FALSE, na.strings = c("", " ", "NA", "."))
