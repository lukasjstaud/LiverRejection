all_ids_by_group_grf <- bind_rows(
  tibble(TRR_ID_CODE = arm2_ID_vect,        FIRST_YEAR_GROUP = "Combined"),
  tibble(TRR_ID_CODE = steroid_id_all_vect, FIRST_YEAR_GROUP = "Steroid"),
