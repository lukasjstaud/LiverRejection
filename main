# Rejection Demographic Table Building
pat_rej_demo_table <- pat_rej_array %>% 
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, AGE, GENDER, ETHCAT, MELD_PELD_LAB_SCORE, TXKID, TXHRT, TXLNG, TXPAN, 
                     PREV_TX, PREV_TX_ANY_N, DON_TY, COLD_ISCH), by = "TRR_ID_CODE") |> 
  group_by(TRR_ID_CODE) %>%
  filter(!(source == 1 & n() > 1)) %>%
  ungroup()%>% 
  mutate(REJ_STAT = 1L) |> # for the following merge this will let me know what is a rejection pt
  left_join(df_deceased_don_fil2, by = "TRR_ID_CODE") |> # adding deceased donor table
  left_join(df_hla_calc, by = "TRR_ID_CODE")

# Control Demographic Table Building
pat_ctrl_demo_table <- pat_ctrl_array %>% 
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, AGE, GENDER, ETHCAT, MELD_PELD_LAB_SCORE, TXKID, TXHRT, TXLNG, TXPAN, 
                     PREV_TX, PREV_TX_ANY_N, DON_TY, COLD_ISCH), by = "TRR_ID_CODE") |> 
  mutate(DISCHARGE_DATE = as.Date(DISCHARGE_DATE)) %>% 
  mutate(REJ_STAT = 0L) %>% # for the following merge this will let me know what is a nonrejection pt
  filter(!TRR_ID_CODE %in% pat_rej_demo_table$TRR_ID_CODE) |> 
  left_join(df_deceased_don_fil2, by = "TRR_ID_CODE") |> # adding deceased donor table
  left_join(df_hla_calc, by = "TRR_ID_CODE")

# Put Together For Future Outcome based analysis
