# Reading data (adjust path and file type as needed)

df_immuno_fol_read <- read.csv("C:/Users/lukas/Documents/Med School/AOT/R/Output/Filtered Data by Date/liver-immuno-follow-up_date-filtered.csv", stringsAsFactors = FALSE)
df_liver_data <- read.csv("C:/Users/lukas/Documents/Med School/AOT/R/Output/Filtered Data by Date/liver-data_date-filtered.csv", stringsAsFactors = FALSE)
df_immuno_induc <- read.csv("C:/Users/lukas/Documents/Med School/AOT/R/Output/Filtered Data by Date/liver-immuno-discharge_unfilter.csv")

df_immuno_fol <- df_immuno_fol_read
# _____________________________________________________________________________
# creating filters of index data
# NOTE: loaded data is already filtered by 10 year date range at this point

# ---------------------------------------------------------------
# Filter1 - Age filter

col_age_range  <- "AGE"     # <- change to your column name
age_min <- 18            # <- change to the value you want 
age_max <- 80         # <- change to the value you want

#print(df_liver_data)

df_liver_data$AGE <- as.numeric(df_liver_data$AGE)

#print(df_liver_data)

df_liver_data_filtered <- df_liver_data %>%
  filter(.data[[col_age_range]] >= age_min & .data[[col_age_range]] <= age_max)  # filters the age

#print(df_liver_data_filtered)

