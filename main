#===============================================================================
# Hazard Ratios: Landmark Cox Models
#-------------------------------------------------------------------------------

# [FIX 3] The reference arm is now an explicit ARGUMENT rather than an emergent
# property of factor level ordering, and the realised direction is echoed back
# in the output. The old code read conf.int[1, ] and assumed it matched the
# label, which is how "Combined vs Control" ended up reporting Control vs
# Combined.
run_coxph_lm <- function(data, ref_arm, label) {
  d <- data %>% mutate(ARM = relevel(droplevels(ARM), ref = ref_arm))
  
  fit <- coxph(Surv(time_lm, event_lm) ~ ARM, data = d)
  s   <- summary(fit)
  
  zph  <- tryCatch(cox.zph(fit), error = function(e) NULL)
  ph_p <- if (!is.null(zph)) zph$table[1, "p"] else NA_real_
  
  tibble(
    Comparison = label,
    Direction  = paste0(rownames(s$conf.int)[1], "  (ref = ", ref_arm, ")"),
    n          = fit$n,
    events     = fit$nevent,
    HR         = s$conf.int[1, "exp(coef)"],
    CI_lower   = s$conf.int[1, "lower .95"],
    CI_upper   = s$conf.int[1, "upper .95"],
    p_value    = s$coefficients[1, "Pr(>|z|)"],
    ph_test_p  = ph_p
  )
}

hr_results_lm <- bind_rows(
  if (!is.null(lm_match_steroid_combined))
    run_coxph_lm(lm_match_steroid_combined$data, ref_arm = "Steroids",
                 label = "Combined vs Steroids"),
  if (!is.null(lm_match_combined_control))
    run_coxph_lm(lm_match_combined_control$data, ref_arm = "Control",
                 label = "Combined vs Control"),
  run_coxph_lm(df_lm_long %>% filter(ARM %in% c("Steroids", "Dual Therapy")),
               ref_arm = "Steroids", label = "Dual Therapy vs Steroids (unmatched)")
)

hr_results_lm

# --- Overall 3-arm model on the unmatched landmark cohort ---
df_lm_3arm <- df_lm_long %>%
  filter(ARM %in% c("Steroids", "Combined", "Control")) %>%
  mutate(ARM = relevel(droplevels(ARM), ref = "Control"))

fit_lm_3arm <- coxph(Surv(time_lm, event_lm) ~ ARM, data = df_lm_3arm)
summary(fit_lm_3arm)
cox.zph(fit_lm_3arm)

# ------------------------------------------------------------------------
# Formatted HR Table
# ------------------------------------------------------------------------
hr_table_lm <- hr_results_lm %>%
  mutate(
    `HR (95% CI)` = sprintf("%.2f (%.2f\u2013%.2f)", HR, CI_lower, CI_upper),
    `P value` = case_when(
      p_value < 0.001 ~ "<0.001",
      TRUE ~ sprintf("%.3f", p_value)
    ),
    `PH test P` = case_when(
      is.na(ph_test_p) ~ NA_character_,
      ph_test_p < 0.001 ~ "<0.001",
      TRUE ~ sprintf("%.3f", ph_test_p)
    )
  ) %>%
  select(Comparison, Direction, n, events, `HR (95% CI)`, `P value`, `PH test P`)

hr_table_lm %>%
  gt() %>%
  cols_label(
    Comparison    = "Comparison",
    Direction     = "Model direction",
    n             = "N",
    events        = "Deaths",
    `HR (95% CI)` = "Hazard Ratio (95% CI)",
    `P value`     = "P value",
    `PH test P`   = "PH Assumption P"
  ) %>%
  tab_header(
    title    = "Hazard Ratios for Mortality (Landmark Cox Models)",
    subtitle = paste0("Landmark at day ", round(LANDMARK_DAY),
                      "; follow-up from landmark to day ", round(LM_HORIZON_LONG))
  ) %>%
  tab_options(table.font.size = 13, data_row.padding = px(4),
              column_labels.font.weight = "bold") %>%
  tab_source_note("LANDMARK DESIGN: exposure defined over the first year post-transplant; only patients still under observation at the landmark are included; the survival clock starts AT the landmark. This removes the immortal time bias present in transplant-anchored analyses of a year-1 exposure. Hazard ratios are therefore for CONDITIONAL survival (given survival to 1 year), not overall post-transplant survival. Matched comparisons use 1:1 nearest-neighbour propensity matching performed WITHIN the landmark cohort (caliper 0.2 SD of the propensity logit; age, gender, ethnicity, MELD, diabetes, cold ischemic time, HLA mismatch). PH Assumption P from cox.zph().")

# --- Forest plots ---
ggforest(fit_lm_3arm, data = df_lm_3arm)

if (!is.null(lm_match_combined_control)) {
  d_fp <- lm_match_combined_control$data %>%
    mutate(ARM = relevel(droplevels(ARM), ref = "Control"))
  ggforest(coxph(Surv(time_lm, event_lm) ~ ARM, data = d_fp), data = d_fp)
}

#===============================================================================
# Covariate-Adjusted Landmark Hazard Ratios
#-------------------------------------------------------------------------------
adj_formula_suffix <- " + AGE + GENDER + MELD_PELD_LAB_SCORE + COLD_ISCH + DIAB_BIN"

run_coxph_lm_adj <- function(data, ref_arm, label) {
  d <- data %>% mutate(ARM = relevel(droplevels(ARM), ref = ref_arm))
  
  # matched frames already carry baseline covariates; unmatched ones may not
  if (!"DIAB_BIN" %in% names(d)) {
    d <- d %>% left_join(baseline_covs, by = "TRR_ID_CODE")
  }
  
  fit <- coxph(as.formula(paste0("Surv(time_lm, event_lm) ~ ARM", adj_formula_suffix)),
               data = d)
  s <- summary(fit)
  
  tibble(
    Comparison = label,
    Direction  = paste0(rownames(s$conf.int)[1], "  (ref = ", ref_arm, ")"),
    n          = fit$n,
    events     = fit$nevent,
    HR         = s$conf.int[1, "exp(coef)"],
    CI_lower   = s$conf.int[1, "lower .95"],
    CI_upper   = s$conf.int[1, "upper .95"],
    p_value    = s$coefficients[1, "Pr(>|z|)"]
  )
}

hr_adj_results_lm <- bind_rows(
  if (!is.null(lm_match_steroid_combined))
    run_coxph_lm_adj(lm_match_steroid_combined$data, "Steroids",
                     "Combined vs Steroids (adjusted)"),
  if (!is.null(lm_match_combined_control))
    run_coxph_lm_adj(lm_match_combined_control$data, "Control",
                     "Combined vs Control (adjusted)")
)

hr_adj_results_lm

hr_adj_table_lm <- hr_adj_results_lm %>%
  mutate(
    `HR (95% CI)` = sprintf("%.2f (%.2f\u2013%.2f)", HR, CI_lower, CI_upper),
    `P value` = case_when(
      p_value < 0.001 ~ "<0.001",
      TRUE ~ sprintf("%.3f", p_value)
    )
  ) %>%
  select(Comparison, Direction, n, events, `HR (95% CI)`, `P value`)

hr_adj_table_lm %>%
  gt() %>%
  cols_label(
    Comparison    = "Comparison",
    Direction     = "Model direction",
    n             = "N",
    events        = "Deaths",
    `HR (95% CI)` = "Adjusted Hazard Ratio (95% CI)",
    `P value`     = "P value"
  ) %>%
  tab_header(title = "Covariate-Adjusted Landmark Hazard Ratios") %>%
  tab_options(table.font.size = 13, data_row.padding = px(4),
              column_labels.font.weight = "bold") %>%
  tab_source_note("Same landmark propensity-matched cohorts as the unadjusted table, with the Cox model additionally adjusted for recipient age, gender, MELD score, cold ischemic time, and diabetes status. Because several of these covariates were also used in the matching, this is adjustment layered on top of matching -- residual imbalance after matching (per the Love plots) is the reason for including it.")

#===============================================================================
# SENSITIVITY ANALYSIS: Time-Varying Exposure Cox Model
#-------------------------------------------------------------------------------
# [FIX 8, second approach] The landmark design removes immortal time bias by
# DISCARDING everyone who died before the landmark. That is safe but wasteful,
# and it changes the estimand to conditional survival.
#
# The time-varying (Mantel-Byar) approach removes the same bias without
# discarding anyone. Every patient begins follow-up at transplant in the
# untreated state and CONTRIBUTES PERSON-TIME TO THE UNTREATED ARM until the day
# they are first treated, at which point they switch arms. A patient who died on
# day 40 having never been treated therefore contributes 40 days of untreated
# person-time and one untreated death -- rather than being misfiled as a Control
# who survived a full year, which is what the original code did.
#
# Data is in counting-process (start, stop] format, so each patient may occupy
# more than one row. No cluster/robust variance is needed: the segments from a
# single patient are non-overlapping in time and the partial likelihood handles
# them correctly.
#-------------------------------------------------------------------------------

arm_all_time <- assign_arm_at_landmark(Inf)   # exposure over all available follow-up

tv_base <- df_survival %>%
  filter(!is.na(PTIME), PTIME > 0) %>%
  select(TRR_ID_CODE, PTIME, event) %>%
  left_join(pat_rej_first %>% select(TRR_ID_CODE, REJ_TX_DAY), by = "TRR_ID_CODE") %>%
  left_join(arm_all_time, by = "TRR_ID_CODE") %>%
  filter(!is.na(ARM))

# Segment 1: untreated person-time, from day 0 until first treatment (or until
# the end of follow-up for patients never treated).
tv_seg_untreated <- tv_base %>%
  mutate(
    tstart = 0,
    tstop = case_when(
      is.na(REJ_TX_DAY)      ~ PTIME,        # never treated
      REJ_TX_DAY <= 0        ~ NA_real_,     # treated at baseline: no untreated time
      REJ_TX_DAY >= PTIME    ~ PTIME,        # treatment recorded at/after last follow-up
      TRUE                   ~ REJ_TX_DAY
    ),
    ev = case_when(
      is.na(REJ_TX_DAY)      ~ as.numeric(event),
      REJ_TX_DAY <= 0        ~ NA_real_,
      REJ_TX_DAY >= PTIME    ~ as.numeric(event),
      TRUE                   ~ 0             # censored at the moment of switching
    ),
    RX_STATE = "None"
  ) %>%
  filter(!is.na(tstop), tstop > tstart)

# Segment 2: treated person-time, from first treatment to end of follow-up.
tv_seg_treated <- tv_base %>%
  filter(!is.na(REJ_TX_DAY), REJ_TX_DAY < PTIME) %>%
  mutate(
    tstart   = pmax(REJ_TX_DAY, 0),
    tstop    = PTIME,
    ev       = as.numeric(event),
    RX_STATE = as.character(ARM)
  ) %>%
  filter(tstop > tstart)

tv_data <- bind_rows(tv_seg_untreated, tv_seg_treated) %>%
  select(TRR_ID_CODE, tstart, tstop, ev, RX_STATE) %>%
  mutate(RX_STATE = factor(RX_STATE,
                           levels = c("None", "Steroids", "Combined",
                                      "Dual Therapy", "Other Rejection"))) %>%
  arrange(TRR_ID_CODE, tstart)

# Sanity checks that this is well-formed counting-process data
stopifnot(all(tv_data$tstop > tv_data$tstart))
message("Time-varying dataset: ", nrow(tv_data), " rows for ",
        n_distinct(tv_data$TRR_ID_CODE), " patients; ",
        sum(tv_data$ev), " deaths")
table(tv_data$RX_STATE, tv_data$ev)

# Administrative censoring at a chosen horizon, measured from TRANSPLANT
truncate_tv <- function(tv, horizon) {
  tv %>%
    filter(tstart < horizon) %>%
    mutate(
      ev    = if_else(tstop > horizon, 0, ev),
      tstop = pmin(tstop, horizon)
    ) %>%
    filter(tstop > tstart)
}

tv_2yr <- truncate_tv(tv_data, 730.5)

fit_tv_2yr <- coxph(Surv(tstart, tstop, ev) ~ RX_STATE, data = tv_2yr)
summary(fit_tv_2yr)
cox.zph(fit_tv_2yr)

tv_hr_table <- summary(fit_tv_2yr)$conf.int %>%
  as.data.frame() %>%
  tibble::rownames_to_column("term") %>%
  transmute(
    Comparison = paste0(str_remove(term, "^RX_STATE"), " vs untreated person-time"),
    `HR (95% CI)` = sprintf("%.2f (%.2f\u2013%.2f)",
                            `exp(coef)`, `lower .95`, `upper .95`),
    `P value` = {
      p <- summary(fit_tv_2yr)$coefficients[, "Pr(>|z|)"]
      if_else(p < 0.001, "<0.001", sprintf("%.3f", p))
    }
  )

tv_hr_table %>%
  gt() %>%
  tab_header(
    title    = "Time-Varying Exposure Cox Model, 2-Year Mortality",
    subtitle = "Sensitivity analysis -- no patients excluded"
  ) %>%
  tab_options(table.font.size = 13, data_row.padding = px(4),
              column_labels.font.weight = "bold") %>%
  tab_source_note("Anti-rejection therapy modelled as a time-dependent covariate: every patient contributes untreated person-time from transplant until their first anti-rejection treatment, then treated person-time thereafter. Unlike the landmark analysis this discards no patients, and unlike the original transplant-anchored analysis it assigns no immortal time to the treated arms. Follow-up administratively censored at 2 years post-transplant. Treatment timing for therapy given during the index admission is approximated (see INPATIENT_RX_DAY).")

#-------------------------------------------------------------------------------
# OPTIONAL: quantify the bias by reproducing the original naive analysis
#-------------------------------------------------------------------------------
# Set to TRUE to fit the ORIGINAL, BIASED model alongside the corrected ones.
# The point is not to report it but to show how far the estimate moves once the
# immortal time is removed -- useful for a supplement or a reviewer response.
# Do not use this HR for anything else.
SHOW_NAIVE_COMPARISON <- FALSE

if (SHOW_NAIVE_COMPARISON) {
  df_naive <- df_survival %>%
    inner_join(arm_all_time, by = "TRR_ID_CODE") %>%
    filter(!is.na(PTIME)) %>%
    mutate(
      event_2yr = if_else(PTIME <= 730.5, event, 0),
      time_2yr  = pmin(PTIME, 730.5),
      ARM = relevel(factor(ARM), ref = "Control")
    ) %>%
    filter(ARM %in% c("Control", "Steroids", "Combined")) %>%
    mutate(ARM = droplevels(ARM))
  
  fit_naive <- coxph(Surv(time_2yr, event_2yr) ~ ARM, data = df_naive)
  
  message("\n--- BIASED (transplant-anchored) vs CORRECTED (landmark) ---")
  message("Biased HRs (immortal time present, DO NOT REPORT):")
  print(round(summary(fit_naive)$conf.int[, c(1, 3, 4)], 3))
  message("Landmark HRs (corrected):")
  print(round(summary(fit_lm_3arm)$conf.int[, c(1, 3, 4)], 3))
  message("Time-varying HRs (corrected, no exclusions):")
  print(round(summary(fit_tv_2yr)$conf.int[, c(1, 3, 4)], 3))
}

