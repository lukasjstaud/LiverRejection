# calculations to fill out demographics table
#-----------
# Rejection variables calculation + dataframe column

age_rej_med <- median(pat_rej_demo_table$AGE, na.rm = TRUE)
gen_rej_count <- pat_rej_demo_table |> # number of dudes
  filter(GENDER == "M") |> 
  nrow()
race_wt_rej_count <- pat_rej_demo_table |> 
  filter(ETHCAT == "1") |> 
  nrow()
race_bl_rej_count <- pat_rej_demo_table |> 
  filter(ETHCAT == "2") |> 
  nrow()
race_his_rej_count <- pat_rej_demo_table |> 
  filter(ETHCAT == "4") |> 
  nrow()
race_asia_rej_count <- pat_rej_demo_table |> 
  filter(ETHCAT == "5") |> 
  nrow()
race_other_rej_count <- nrow(pat_rej_demo_table) - sum(race_wt_rej_count, race_bl_rej_count, race_his_rej_count, race_asia_rej_count)
meld_rej_med <- median(pat_rej_demo_table$MELD_PELD_LAB_SCORE, na.rm = TRUE)
txkid_rej_count <- pat_rej_demo_table |> 
  filter(TXKID %in% c("L","R","E")) |> 
  nrow()
txhrt_rej_count <- pat_rej_demo_table |> 
  filter(TXHRT  == "Y") |> 
  nrow()
txlng_rej_count <- pat_rej_demo_table |> 
  filter(TXLNG %in% c("L","R","E")) |> 
  nrow()
txpan_rej_count <- pat_rej_demo_table |> 
  filter(TXPAN %in% c("L","R","E")) |> 
  nrow()
txliv_rej_count <- nrow(pat_rej_demo_table) - sum(txkid_rej_count,txhrt_rej_count,txlng_rej_count,txpan_rej_count)
prev_liver_rej <- pat_rej_demo_table |> 
  filter(PREV_TX == "Y") |> 
  nrow()
prev_tx_1_rej_count <- pat_rej_demo_table |> 
  filter(PREV_TX_ANY_N == "1") |> 
  nrow()
prev_tx_2_rej_count <- pat_rej_demo_table |> 
  filter(PREV_TX_ANY_N == "2") |> 
  nrow()
prev_tx_3_rej_count <- pat_rej_demo_table |> 
  filter(PREV_TX_ANY_N == "3") |> 
  nrow()
prev_tx_0_rej_count <- sum(is.na(pat_rej_demo_table$PREV_TX_ANY_N))
cold_isch_time_rej <- median(pat_rej_demo_table$COLD_ISCH, na.rm = TRUE)
liv_don_rej <- pat_rej_demo_table |> 
  filter(DON_TY == "L") |> 
  nrow()

mean_rej <- c(
  nrow(pat_rej_demo_table), # gives me a count of n
  age_rej_med,           # 1  Recipient Age
  gen_rej_count,         # 2  Male Gender
  NA,                    # 3  "Race, n(%)" header
  race_wt_rej_count,     # 4  White
  race_bl_rej_count,     # 5  Black
  race_his_rej_count,    # 6  Hispanic
