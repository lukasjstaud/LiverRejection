format_table1 <- function() {
  tbl_data %>%
    filter(demo_label1 != "n") %>%
    mutate(
      is_header = is_header_flag,                              # [FIX 1]
      is_median = is_median_row(demo_label1, std_rej),         # [FIX 1]
      mean_rej_fmt   = if_else(is_median, NA_character_, fmt_count(mean_rej)),    # [FIX 14]
      mean_ritux_fmt = if_else(is_median, NA_character_, fmt_count(mean_ritux)),
      mean_ctrl_fmt  = if_else(is_median, NA_character_, fmt_count(mean_ctrl)),
      Rejection = case_when(
        is_header ~ NA_character_,
        is_median ~ paste0(fmt_count(mean_rej), " ", std_rej),
        TRUE ~ paste0(mean_rej_fmt, " (", sprintf("%.1f", as.numeric(std_rej)), "%)")
      ),
      Rituxan = case_when(
        is_header ~ NA_character_,
        is_median ~ paste0(fmt_count(mean_ritux), " ", std_ritux),
        TRUE ~ paste0(mean_ritux_fmt, " (", sprintf("%.1f", as.numeric(std_ritux)), "%)")
      ),
      Control = case_when(
        is_header ~ NA_character_,
        is_median ~ paste0(fmt_count(mean_ctrl), " ", std_ctrl),
        TRUE ~ paste0(mean_ctrl_fmt, " (", sprintf("%.1f", as.numeric(std_ctrl)), "%)")
      ),
      Variable = if_else(is_header, demo_label1, paste0("    ", demo_label1))
    ) %>%
    select(Variable, Rejection, Rituxan, Control, is_header)
}

demo_tbl1 <- format_table1()

demo_tbl1 %>%
  select(-is_header) %>%
  gt() %>%
  cols_label(
    Variable = "Characteristic",
    Rejection = paste0("Rejection (n = ", num_rej, ")"),
    Rituxan = paste0("Rituxan (n = ", num_ritux, ")"),
    Control = paste0("Control (n = ", num_ctrl, ")")
  ) %>%
  tab_style(
    style = cell_text(weight = "bold"),
    locations = cells_body(rows = demo_tbl1$is_header)
  ) %>%
  tab_style(
    style = cell_text(align = "left"),
    locations = cells_column_labels(columns = Variable)
  ) %>%
  cols_align(align = "center", columns = c(Rejection, Rituxan, Control)) %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold"
  ) %>%
  tab_source_note("Values are n (%) or median (IQR) as indicated.")

# ==============================================================================
# Propensity Score Matching: Combined vs Steroid, Combined vs Control
# ------------------------------------------------------------------------------

prep_match_df <- function(df) {
  df %>%
    mutate(
      DIAB_BIN = case_when(
        as.numeric(DIAB) %in% 2:5 ~ 1,
        as.numeric(DIAB) == 1     ~ 0,
        TRUE                      ~ NA_real_
      ),
      GENDER = factor(GENDER),
      ETHCAT = factor(ETHCAT),
      DON_TY = factor(DON_TY)
    )
}

match_covariates <- c("AGE", "GENDER", "ETHCAT", "MELD_PELD_LAB_SCORE", 
                      "DIAB_BIN", "COLD_ISCH", "MM_TOTAL")

match_formula <- as.formula(paste("treat ~", paste(match_covariates, collapse = " + ")))

# [FIX 9] drop_na() on the matching covariates can quietly gut the cohort --
# MM_TOTAL is NA whenever ANY of the six alleles is missing, which in UNOS is
# common, and cold ischemic time is patchy too. This reports complete-case
# attrition per arm AND per covariate so you can see exactly which variable is
# doing the damage before trusting the matched Ns.
report_complete_case_loss <- function(df, label) {
  n_before <- nrow(df)
  n_after  <- nrow(tidyr::drop_na(df, all_of(match_covariates)))
  message("\n[", label, "] complete-case attrition on matching covariates:")
  message("  rows before drop_na: ", n_before,
          " | after: ", n_after,
          " | lost: ", n_before - n_after,
          " (", sprintf("%.1f", 100 * (n_before - n_after) / max(n_before, 1)), "%)")
  
  per_arm <- df %>%
    group_by(treat) %>%
    summarise(before = n(),
              after = sum(complete.cases(across(all_of(match_covariates)))),
              .groups = "drop")
  print(per_arm)
  
  miss_by_var <- sapply(match_covariates, function(v) sum(is.na(df[[v]])))
  message("  missing count by covariate:")
  print(miss_by_var[order(-miss_by_var)])
  invisible(NULL)
}

# ------------------------------------------------------------------------------
# Comparison 1: Combined vs Steroid
# ------------------------------------------------------------------------------
match_df_combined_steroid_raw <- bind_rows(
  prep_match_df(pat_combined_demo_table) %>% mutate(treat = 1),
  prep_match_df(pat_steroid_demo_table)  %>% mutate(treat = 0)
) %>%
  select(TRR_ID_CODE, treat, all_of(match_covariates))

report_complete_case_loss(match_df_combined_steroid_raw, "Combined vs Steroid")   # [FIX 9]

match_df_combined_steroid <- match_df_combined_steroid_raw %>% drop_na()

set.seed(1234)  # reproducibility of the matching algorithm

# [FIX 10] caliper added. 1:1 nearest-neighbour with no caliper will force a
# match for every treated unit no matter how far away the nearest control is,
# which with small treated arms produces pairs that are not comparable at all.
# 0.2 SD of the propensity logit is the conventional cutoff (Austin 2011);
# std.caliper = TRUE makes it SD-scaled rather than absolute.
m_combined_steroid <- matchit(
  match_formula,
  data         = match_df_combined_steroid,
  method       = "nearest",
  distance     = "logit",
  ratio        = 1,
  caliper      = 0.2,
  std.caliper  = TRUE
)

summary(m_combined_steroid)  # check balance (Std. Mean Diff should shrink toward 0)

# [FIX 10] with a caliper, some treated units will now go UNMATCHED. Report how
# many, since a large drop changes who the estimand applies to.
message("[Combined vs Steroid] treated units unmatched by caliper: ",
        sum(m_combined_steroid$treat == 1 & is.na(m_combined_steroid$subclass)))

matched_combined_steroid <- match.data(m_combined_steroid)

combined_ids_1 <- matched_combined_steroid %>% filter(treat == 1) %>% pull(TRR_ID_CODE)
steroid_ids    <- matched_combined_steroid %>% filter(treat == 0) %>% pull(TRR_ID_CODE)

pat_combined_demo_table_m_steroid <- pat_combined_demo_table %>% filter(TRR_ID_CODE %in% combined_ids_1)
pat_steroid_demo_table_m          <- pat_steroid_demo_table  %>% filter(TRR_ID_CODE %in% steroid_ids)

# ------------------------------------------------------------------------------
# Comparison 2: Combined vs Control (No Rejection)
# ------------------------------------------------------------------------------
match_df_combined_ctrl_raw <- bind_rows(
  prep_match_df(pat_combined_demo_table) %>% mutate(treat = 1),
  prep_match_df(pat_ctrl_demo_table)     %>% mutate(treat = 0)
) %>%
  select(TRR_ID_CODE, treat, all_of(match_covariates))

report_complete_case_loss(match_df_combined_ctrl_raw, "Combined vs Control")   # [FIX 9]

match_df_combined_ctrl <- match_df_combined_ctrl_raw %>% drop_na()

set.seed(1234)

m_combined_ctrl <- matchit(
  match_formula,
  data         = match_df_combined_ctrl,
  method       = "nearest",
  distance     = "logit",
  ratio        = 1,
  caliper      = 0.2,      # [FIX 10]
  std.caliper  = TRUE
)

summary(m_combined_ctrl)

message("[Combined vs Control] treated units unmatched by caliper: ",
        sum(m_combined_ctrl$treat == 1 & is.na(m_combined_ctrl$subclass)))

matched_combined_ctrl <- match.data(m_combined_ctrl)

combined_ids_2 <- matched_combined_ctrl %>% filter(treat == 1) %>% pull(TRR_ID_CODE)
ctrl_ids       <- matched_combined_ctrl %>% filter(treat == 0) %>% pull(TRR_ID_CODE)

pat_combined_demo_table_m_ctrl <- pat_combined_demo_table %>% filter(TRR_ID_CODE %in% combined_ids_2)
pat_ctrl_demo_table_m          <- pat_ctrl_demo_table     %>% filter(TRR_ID_CODE %in% ctrl_ids)

