# Year-2 Anti-Rejection Treatment, Stratified by First-Year Treatment Group
#-------------------------------------------------------------------------------
# [FIX 4] ctrl_id_vect is now the cleaned control cohort, so the Control arm in
# this landmark analysis no longer contains patients who were treated for
# rejection later in year 1.

# --- Step 1: Landmark cohort -- patients known to still be followed at day 365 ---
landmark_ids_yr1 <- df_liver_data_filtered %>%
  filter(PTIME >= 365.25) %>%
  pull(TRR_ID_CODE)

# --- Step 2: Build the YEAR-2-ONLY follow-up window (not cumulative from TX) ---
# [FIX 18] duplicate TX_DATE removed from select()
df_immuno_fol_yr2 <- df_immuno_fol_read %>%
  filter(TRR_ID_CODE %in% tx_ids_to_keep) %>%
  filter(TRR_ID_CODE %in% landmark_ids_yr1) %>%   # restrict to patients at risk through yr2
  left_join(df_liver_data_filtered %>%
              select(TRR_ID_CODE, TX_DATE, DISCHARGE_DATE), by = "TRR_ID_CODE") %>%
  filter(!is.na(TX_DATE)) %>%
  mutate(
    PX_STAT_DATE_FOL = as.Date(PX_STAT_DATE_FOL),
    TX_DATE = as.Date(TX_DATE)
  ) %>%
  mutate(FOL_DATE_DAYS_DELTA = time_length(interval(TX_DATE, PX_STAT_DATE_FOL), "days")) %>%
  filter(FOL_DATE_DAYS_DELTA > 365.25 & FOL_DATE_DAYS_DELTA <= 730.5) %>%   # YEAR 2 ONLY
  arrange(PX_STAT_DATE_FOL) %>%
  mutate(NUM_ANTI_REJ_RXED_ROW = rowSums(across(all_of(COLS_TO_CHECK)) == 1, na.rm = TRUE))

# --- Step 3: Per-patient summary of year-2 anti-rejection treatment ---
df_yr2_patient_summary <- df_immuno_fol_yr2 %>%
  group_by(TRR_ID_CODE) %>%
  summarise(
    across(all_of(COLS_TO_CHECK), ~ as.integer(any(.x == 1, na.rm = TRUE))),
    NUM_FOLLOWUPS_YR2 = n(),
    .groups = "drop"
  ) %>%
  mutate(
    NUM_DRUGS_YR2    = rowSums(across(all_of(COLS_TO_CHECK))),
    ANY_ANTI_REJ_YR2 = as.integer(NUM_DRUGS_YR2 >= 1)
  )

# --- Step 4: Attach first-year group label to the FULL landmark cohort ---
all_ids_by_group <- bind_rows(
  tibble(TRR_ID_CODE = arm2_ID_vect,         FIRST_YEAR_GROUP = "Combined"),
  tibble(TRR_ID_CODE = steroid_id_all_vect,  FIRST_YEAR_GROUP = "Steroid"),
  tibble(TRR_ID_CODE = ctrl_id_vect,         FIRST_YEAR_GROUP = "Control")
) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE) %>%     # [FIX 4] guard against an ID landing in two arms
  filter(TRR_ID_CODE %in% landmark_ids_yr1) %>%
  mutate(FIRST_YEAR_GROUP = factor(FIRST_YEAR_GROUP, levels = c("Steroid", "Combined", "Control")))

df_yr2_by_group <- all_ids_by_group %>%
  left_join(df_yr2_patient_summary, by = "TRR_ID_CODE") %>%
  mutate(
    HAS_YR2_FOLLOWUP = !is.na(NUM_FOLLOWUPS_YR2),
    ANY_ANTI_REJ_YR2 = coalesce(ANY_ANTI_REJ_YR2, 0L),
    across(all_of(COLS_TO_CHECK), ~ coalesce(.x, 0L))
  )

# NOTE: patients with HAS_YR2_FOLLOWUP == FALSE have no recorded follow-up visit
# in the year-2 window at all -- they are coded ANY_ANTI_REJ_YR2 = 0, which
# assumes "no visit" means "no rejection," not "unknown."

# ------------------------------------------------------------------------
# Step 5: Group-level summary
# ------------------------------------------------------------------------
year2_group_summary <- df_yr2_by_group %>%
  group_by(FIRST_YEAR_GROUP) %>%
  summarise(
    N                    = n(),
    N_with_yr2_followup  = sum(HAS_YR2_FOLLOWUP),
    N_rejected_yr2       = sum(ANY_ANTI_REJ_YR2),
    Pct_rejected_yr2     = 100 * N_rejected_yr2 / N,
    .groups = "drop"
  )

year2_group_summary %>%
  gt() %>%
  fmt_number(columns = Pct_rejected_yr2, decimals = 1) %>%
