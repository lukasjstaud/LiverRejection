#--------------------------------------------------------------------------------------------------
# Creating running counts of follow up treatments for anti-rejection therapy and checking for combo therapy

# Below commented out bc it takes so damn long to run
df_immuno_fol <- df_immuno_fol %>%
  # running count
  mutate(REJECT_RUNNING_COUNT = 0L) %>%
  group_by(TRR_ID_CODE) %>%
  mutate(
    REJECT_RUNNING_COUNT = cumsum(if_any(all_of(COLS_TO_CHECK), ~ !is.na(.) & . == 1))
  ) %>%
  ungroup() %>%
  # combo therapy rx'ed?
  mutate(NUM_ANTI_REJ_RXED = 0L) |>
  mutate(NUM_ANTI_REJ_RXED = rowSums(across(all_of(COLS_TO_CHECK)) == 1, na.rm = TRUE))

# store data so that I dont have to keep calculating it
df_immuno_fol_calc <- df_immuno_fol

