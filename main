  stats    = "mean.diffs",
  abs      = TRUE,                # absolute value of std. mean diff (easier to read)
  var.order = "unadjusted",       # sorts by size of the pre-match imbalance
  thresholds = c(m = 0.1),        # draws a reference line at the common 0.1 cutoff
  title    = "Covariate Balance: Combined vs Steroid",
  sample.names = c("Unmatched", "Matched")
)

