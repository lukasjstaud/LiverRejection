#----------------------------------------------------------------------
# IQR + Percents for demographic data

# Rejections
num_rej <- nrow(pat_rej_demo_table)

age_rej_q1  <- quantile(pat_rej_demo_table$AGE, 0.25, na.rm = TRUE)
age_rej_q3  <- quantile(pat_rej_demo_table$AGE, 0.75, na.rm = TRUE)
age_rej_qstring <- paste0(" (", age_rej_q1, "–", age_rej_q3, ")")

gen_rej_perc <- 100*gen_rej_count/num_rej

race_wt_rej_perc <- 100*race_wt_rej_count/num_rej
race_bl_rej_perc <- 100*race_bl_rej_count/num_rej
race_his_rej_perc <- 100*race_his_rej_count/num_rej
race_asia_rej_perc <- 100*race_asia_rej_count/num_rej
race_other_rej_perc <- 100*race_other_rej_count/num_rej

