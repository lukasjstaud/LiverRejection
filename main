) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE) %>%     # [FIX 4]
  filter(TRR_ID_CODE %in% landmark_ids_grf_yr1) %>%
  mutate(FIRST_YEAR_GROUP = factor(FIRST_YEAR_GROUP, levels = c("Steroid", "Combined", "Control")))

df_graft_yr2_by_group <- all_ids_by_group_grf %>%
  left_join(df_graft_yr2 %>%
              select(TRR_ID_CODE, ANY_GRF_FAIL_YR2, GRF_TIME_DAYS) %>%
              distinct(TRR_ID_CODE, .keep_all = TRUE),        # [FIX 7]
            by = "TRR_ID_CODE")

year2_grf_group_summary <- df_graft_yr2_by_group %>%
  group_by(FIRST_YEAR_GROUP) %>%
  summarise(
    N                = n(),
    N_grf_fail_yr2   = sum(ANY_GRF_FAIL_YR2, na.rm = TRUE),
    Pct_grf_fail_yr2 = 100 * N_grf_fail_yr2 / N,
    .groups = "drop"
  )

year2_grf_group_summary %>%
  gt() %>%
  fmt_number(columns = Pct_grf_fail_yr2, decimals = 1) %>%
  cols_label(
    FIRST_YEAR_GROUP  = "First-Year Group",
    N                 = "N (landmark cohort)",
    N_grf_fail_yr2    = "N Graft Failures in Yr2",
    Pct_grf_fail_yr2   = "% Graft Failure in Yr2"
  ) %>%
  tab_header(title = "Graft Failure During Year 2, by First-Year Treatment Group") %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold"
  ) %>%
  tab_source_note("Landmark cohort restricted to patients whose graft was known functioning through day 365 (GRF_TIME_DAYS >= 365.25). Year 2 defined as day 365.25-730.5 post-transplant.")

tab_grf_yr2 <- table(df_graft_yr2_by_group$FIRST_YEAR_GROUP, df_graft_yr2_by_group$ANY_GRF_FAIL_YR2)
tab_grf_yr2
safe_chisq_or_fisher(tab_grf_yr2)


#===============================================================================
# Statistical Analysis: Year-2 Graft Failure by First-Year Group
#-------------------------------------------------------------------------------

covariates_grf_yr2 <- df_liver_data_filtered %>%
  select(TRR_ID_CODE, AGE, GENDER, MELD_PELD_LAB_SCORE, COLD_ISCH, DIAB) %>%
  mutate(
    DIAB_BIN = case_when(
      as.numeric(DIAB) %in% 2:5 ~ 1,
      as.numeric(DIAB) == 1     ~ 0,
      TRUE                      ~ NA_real_
    ),
    GENDER = factor(GENDER)
  ) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE) %>%              # [FIX 7]
  left_join(df_hla_calc %>% select(TRR_ID_CODE, MM_TOTAL), by = "TRR_ID_CODE")

df_grf_yr2_model <- df_graft_yr2_by_group %>%
  left_join(covariates_grf_yr2, by = "TRR_ID_CODE") %>%
  mutate(FIRST_YEAR_GROUP = relevel(FIRST_YEAR_GROUP, ref = "Control"))

stopifnot(nrow(df_graft_yr2_by_group) == nrow(df_grf_yr2_model))   # [FIX 7]

fit_grf_unadj <- glm(ANY_GRF_FAIL_YR2 ~ FIRST_YEAR_GROUP, data = df_grf_yr2_model, family = binomial)
summary(fit_grf_unadj)

fit_grf_null <- glm(ANY_GRF_FAIL_YR2 ~ 1, data = df_grf_yr2_model, family = binomial)
anova(fit_grf_null, fit_grf_unadj, test = "LRT")

or_grf_unadj <- tidy_glm_or(fit_grf_unadj) %>% mutate(Model = "Unadjusted")

fit_grf_adj <- glm(
  ANY_GRF_FAIL_YR2 ~ FIRST_YEAR_GROUP + AGE + GENDER + MELD_PELD_LAB_SCORE + COLD_ISCH + DIAB_BIN + MM_TOTAL,
  data = df_grf_yr2_model,
  family = binomial
)
summary(fit_grf_adj)

or_grf_adj <- tidy_glm_or(fit_grf_adj) %>%
  filter(str_detect(term, "^FIRST_YEAR_GROUP")) %>%
  mutate(Model = "Adjusted")

df_grf_yr2_model_steroid_ref <- df_grf_yr2_model %>%
  mutate(FIRST_YEAR_GROUP = relevel(FIRST_YEAR_GROUP, ref = "Steroid"))

fit_grf_unadj_steroid_ref <- glm(ANY_GRF_FAIL_YR2 ~ FIRST_YEAR_GROUP, data = df_grf_yr2_model_steroid_ref, family = binomial)
fit_grf_adj_steroid_ref <- glm(
  ANY_GRF_FAIL_YR2 ~ FIRST_YEAR_GROUP + AGE + GENDER + MELD_PELD_LAB_SCORE + COLD_ISCH + DIAB_BIN + MM_TOTAL,
  data = df_grf_yr2_model_steroid_ref,
  family = binomial
)

or_grf_unadj_combined_vs_steroid <- tidy_glm_or(fit_grf_unadj_steroid_ref) %>%
  filter(term == "FIRST_YEAR_GROUPCombined") %>%
  mutate(term = "FIRST_YEAR_GROUPCombined (ref = Steroid)", Model = "Unadjusted")

or_grf_adj_combined_vs_steroid <- tidy_glm_or(fit_grf_adj_steroid_ref) %>%
  filter(term == "FIRST_YEAR_GROUPCombined") %>%
  mutate(term = "FIRST_YEAR_GROUPCombined (ref = Steroid)", Model = "Adjusted")

or_grf_results_yr2 <- bind_rows(
  or_grf_unadj, or_grf_adj,
  or_grf_unadj_combined_vs_steroid, or_grf_adj_combined_vs_steroid
) %>%
  mutate(
    Comparison = case_when(
      term == "FIRST_YEAR_GROUPSteroid"                 ~ "Steroid vs Control",
      term == "FIRST_YEAR_GROUPCombined"                 ~ "Combined vs Control",
      term == "FIRST_YEAR_GROUPCombined (ref = Steroid)" ~ "Combined vs Steroid",
      TRUE ~ term
    )
  ) %>%
  select(Comparison, Model, OR, CI_lower, CI_upper, p_value)

or_grf_results_yr2

or_grf_table_yr2 <- or_grf_results_yr2 %>%
  mutate(
    `OR (95% CI)` = sprintf("%.2f (%.2f\u2013%.2f)", OR, CI_lower, CI_upper),
    `P value` = case_when(
      p_value < 0.001 ~ "<0.001",
      TRUE ~ sprintf("%.3f", p_value)
    )
  ) %>%
  select(Comparison, Model, `OR (95% CI)`, `P value`) %>%
  arrange(Comparison, Model)

or_grf_table_yr2 %>%
  gt(groupname_col = "Comparison") %>%
  cols_label(
    Model         = "Model",
    `OR (95% CI)`= "Odds Ratio (95% CI)",
    `P value`    = "P value"
  ) %>%
  tab_header(title = "Odds of Graft Failure in Year 2, by First-Year Treatment Group") %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold",
    row_group.font.weight = "bold"
  ) %>%
  tab_source_note("OR > 1 indicates higher odds of graft failure in year 2 relative to the comparison group. Adjusted model controls for recipient age, gender, MELD score, cold ischemic time, diabetes status, and HLA mismatch level (MM_TOTAL). Landmark cohort restricted to patients with a functioning graft through 1 year (GRF_TIME_DAYS >= 365.25).")

