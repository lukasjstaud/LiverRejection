#==============================================================================
# Survival Analysis  --  LANDMARK DESIGN
#-------------------------------------------------------------------------------
# [FIX 8] IMMORTAL TIME BIAS.
#
# The previous version of this section defined group membership from
# anti-rejection treatment received during YEAR 1, but started the survival
# clock at TRANSPLANT (day 0). That is immortal time bias, and it is not a
# small effect:
#
#   * A patient who died on day 40 could not possibly have received a month-6
#     rejection treatment. They are therefore forced into the Control arm by
#     construction -- not because they avoided rejection, but because they died
#     before they could be observed having one.
#   * Every patient in the Steroids / Combined / Dual arms is GUARANTEED to have
#     survived at least until their treatment date. That guaranteed survival is
#     "immortal time," and the naive KM curve credits it to the treatment.
#   * The result is that treated arms look structurally protected early on, and
#     the Control arm absorbs all the early deaths. The bias runs in the
#     direction of making anti-rejection treatment look beneficial.
#
# The year-2 sections already handled this correctly with landmark_ids_yr1.
# This section applies the same logic to the primary survival analysis, plus a
# time-varying-exposure Cox model as a sensitivity analysis that uses the full
# follow-up without discarding anyone.
#
# DESIGN:
#   1. Fix a landmark day L (default 365.25, matching the year-2 sections).
#   2. Exposure is whatever anti-rejection treatment was given in [0, L).
#   3. Only patients still under observation AT L enter the analysis.
#   4. The survival clock is reset to start at L.
#   Nobody in any arm can have died before L, so no arm carries immortal time.
#
# CONSEQUENCE FOR INTERPRETATION -- READ THIS:
#   Time on the x-axis is now DAYS SINCE THE LANDMARK, not days since
#   transplant. With L = 365.25, the "1-year" curve covers post-transplant
#   years 1-2 and the "2-year" curve covers years 1-3. These are conditional
#   survival estimates (survival given you reached 1 year), which is the correct
#   quantity for a year-1 exposure, but it is NOT the same estimand as the old
#   plots. Label it as such in any manuscript.
#
#   Everyone who died in year 1 is excluded. That is the price of the landmark
#   design and the reason the time-varying model below is included alongside it.
#-------------------------------------------------------------------------------

# [FIX 16] fix_origin() previously added a bare scale_x_continuous(), which
# REPLACES the scale survminer built from break.time.by -- so the 90-day /
# 180-day tick marks were silently discarded and ggplot emitted a "Scale for x
# is already present" message on every plot. The replacement scale now carries
# the breaks explicitly.
fix_origin <- function(p, break_by = NULL, max_time = NULL) {
  x_scale <- if (!is.null(break_by) && !is.null(max_time)) {
    ggplot2::scale_x_continuous(
      expand = ggplot2::expansion(mult = c(0, 0.02)),
      breaks = seq(0, max_time, by = break_by)
    )
  } else {
    ggplot2::scale_x_continuous(expand = ggplot2::expansion(mult = c(0, 0.02)))
  }
  
  p$plot <- suppressMessages(
    p$plot +
      x_scale +
      ggplot2::scale_y_continuous(expand = ggplot2::expansion(mult = c(0, 0.02)),
                                  limits = c(0, 1))
  )
  # keep the risk table on the same x scale so the columns stay aligned
  if (!is.null(p$table)) {
    p$table <- suppressMessages(p$table + x_scale)
  }
  p
}

#-------------------------------------------------------------------------------
# Step 0: analysis parameters
#-------------------------------------------------------------------------------
# LANDMARK_DAY is the single knob that controls this whole section. Setting it
# to 365.25 keeps the exposure definition identical to the rest of the script.
# Setting it lower (e.g. 90) retains far more patients and more post-landmark
# follow-up, at the cost of only counting rejections treated in the first 90
# days -- rejections after that are then treated as non-exposure (a
# treat-as-of-landmark / intention-to-treat-at-landmark analysis). Running both
# and comparing is a reasonable sensitivity analysis.
LANDMARK_DAY <- 365.25

# Horizons are measured FROM THE LANDMARK, not from transplant.
LM_HORIZON_SHORT <- 365.25   # 1 year of post-landmark follow-up
LM_HORIZON_LONG  <- 730.5    # 2 years of post-landmark follow-up

# Day (post-transplant) assigned to anti-rejection therapy given during the
# index admission. The UNOS discharge file records THAT it was given, not WHEN,
# so day 0 is used: it assigns these patients no immortal time at all. Setting
# this to a positive value would credit them unexposed person-time they may not
# have had. Sensitivity: try DAYS_HOSP_SP_TX / 2.
INPATIENT_RX_DAY <- 0

#-------------------------------------------------------------------------------
# Step 1: day of FIRST anti-rejection treatment, per patient
#-------------------------------------------------------------------------------
# This is the variable the old code never had, and without it a landmark or
# time-varying design is impossible -- which is why the bias went unnoticed.
#
# Sources and their timing caveats:
#   source == 1 (index admission) -> INPATIENT_RX_DAY, see above.
#   source == 2 (outpatient)      -> FOL_DATE_DAYS_DELTA, the date of the
#      follow-up VISIT at which the drug was recorded. The actual treatment
#      happened at some point in the interval since the previous visit, so this
#      is an upper bound on the true treatment day. Using it grants slightly
#      MORE unexposed person-time than reality, which is conservative here.
pat_rej_first <- pat_rej_array %>%
  group_by(TRR_ID_CODE) %>%
  slice_min(order_by = source, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  mutate(
    REJ_TX_DAY = if_else(source == 1L,
                         as.numeric(INPATIENT_RX_DAY),
                         as.numeric(FOL_DATE_DAYS_DELTA))
  )

# Sanity: every rejector must have a usable treatment day
message("Rejectors with unusable REJ_TX_DAY (should be 0): ",
        sum(is.na(pat_rej_first$REJ_TX_DAY)))
summary(pat_rej_first$REJ_TX_DAY)

#-------------------------------------------------------------------------------
# Step 2: arm assignment AS OF a given landmark
#-------------------------------------------------------------------------------
# Arms are mutually exclusive and are derived from the patient's FIRST
# anti-rejection event only. Note this differs subtly from the original
# steroid_id_all_vect / arm2_ID_vect, which were built from pat_rej_array
# WITHOUT deduplication -- a patient with both an inpatient and an outpatient
# record could be classified from whichever row happened to match. First-event
# classification is the one that is coherent with a time-to-event design.
assign_arm_at_landmark <- function(landmark_day) {
  
  treated_before <- pat_rej_first %>%
    filter(!is.na(REJ_TX_DAY), REJ_TX_DAY < landmark_day)
  
  mono <- treated_before %>% filter(NUM_ANTI_REJ_RXED < 2)
  
  steroid_lm  <- mono %>%
    filter(STEROIDS_ANTIREJ == 1) %>% pull(TRR_ID_CODE)
  
  combined_lm <- mono %>%
    filter(SIMULECT_ANTIREJ == 1 | THYMOGLOBULIN_ANTIREJ == 1 | RITUXAN_ANTIREJ == 1) %>%
    pull(TRR_ID_CODE)
  
  dual_lm <- treated_before %>%
    filter(STEROIDS_ANTIREJ == 1,
           SIMULECT_ANTIREJ == 1 | THYMOGLOBULIN_ANTIREJ == 1 | RITUXAN_ANTIREJ == 1) %>%
    pull(TRR_ID_CODE)
  
  # Controls: assessed at least once (so "no rejection" means observed, not
  # missing) and no anti-rejection therapy recorded before the landmark.
  assessed_ids   <- unique(df_immuno_fol_calc$TRR_ID_CODE)
  control_lm     <- setdiff(assessed_ids, treated_before$TRR_ID_CODE)
  
  tibble(TRR_ID_CODE = unique(c(treated_before$TRR_ID_CODE, control_lm))) %>%
    mutate(ARM = case_when(
      TRR_ID_CODE %in% dual_lm     ~ "Dual Therapy",
      TRR_ID_CODE %in% steroid_lm  ~ "Steroids",
      TRR_ID_CODE %in% combined_lm ~ "Combined",
      TRR_ID_CODE %in% control_lm  ~ "Control",
      TRUE                         ~ "Other Rejection"
    ))
}

arm_at_landmark <- assign_arm_at_landmark(LANDMARK_DAY)
table(arm_at_landmark$ARM, useNA = "ifany")

# --- Reconciliation against the original ID vectors -------------------------
# At LANDMARK_DAY = 365.25 these should agree almost exactly. Any difference is
# the deduplication effect described above, NOT the landmark itself. Reported
# rather than asserted, so a real discrepancy is visible instead of fatal.
reconcile_arm <- function(arm_name, old_vect) {
  new_vect <- arm_at_landmark %>% filter(ARM == arm_name) %>% pull(TRR_ID_CODE)
  message(sprintf("  %-14s new n=%4d | old n=%4d | new-only=%3d | old-only=%3d",
                  arm_name, length(new_vect), length(old_vect),
                  length(setdiff(new_vect, old_vect)),
                  length(setdiff(old_vect, new_vect))))
}
message("Arm reconciliation (first-event classification vs original vectors):")
reconcile_arm("Steroids",     steroid_id_all_vect)
reconcile_arm("Combined",     arm2_ID_vect)
reconcile_arm("Dual Therapy", dual_therapy_id_vect)
reconcile_arm("Control",      ctrl_id_vect)

#-------------------------------------------------------------------------------
# Step 3: base survival frame
#-------------------------------------------------------------------------------
df_survival <- df_liver_data_filtered |> 
  select(TRR_ID_CODE, TX_DATE, COMPOSITE_DEATH_DATE, RETXDATE, PTIME, PX_STAT, PX_STAT_DATE) |> 
  mutate(PTIME = suppressWarnings(as.numeric(PTIME))) |>          # [FIX 19]
  distinct(TRR_ID_CODE, .keep_all = TRUE) |>                      # [FIX 7]
  mutate(event = ifelse(PX_STAT == "D", 1, 0))   # confirm "D" is your death code

# Baseline covariates, assembled once, for matching inside the landmark cohort
baseline_covs <- df_liver_data_filtered %>%
  select(TRR_ID_CODE, AGE, GENDER, ETHCAT, MELD_PELD_LAB_SCORE, COLD_ISCH, DIAB) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE) %>%                     # [FIX 7]
  left_join(df_hla_calc %>% select(TRR_ID_CODE, MM_TOTAL), by = "TRR_ID_CODE") %>%
  mutate(
    DIAB_BIN = case_when(
      as.numeric(DIAB) %in% 2:5 ~ 1,
      as.numeric(DIAB) == 1     ~ 0,
      TRUE                      ~ NA_real_
    ),
    GENDER = factor(GENDER),
    ETHCAT = factor(ETHCAT)
  )

#-------------------------------------------------------------------------------
# Step 4: build the landmark survival dataset
#-------------------------------------------------------------------------------
# This is where the bias is actually removed. Three things happen together and
# all three are necessary:
#   (a) arms are assigned from exposure BEFORE the landmark,
#   (b) patients not still under observation AT the landmark are DROPPED,
#   (c) the clock is reset so t = 0 is the landmark, not transplant.
# Doing (a) without (b) and (c) is exactly the original bug.
build_landmark_surv <- function(landmark_day, horizon_days) {
  arms <- assign_arm_at_landmark(landmark_day)
  
  out <- df_survival %>%
    inner_join(arms, by = "TRR_ID_CODE") %>%
    filter(!is.na(PTIME), PTIME >= landmark_day) %>%     # (b) landmark restriction
    mutate(
      time_raw = PTIME - landmark_day,                   # (c) clock reset
      event_lm = if_else(time_raw <= horizon_days, event, 0),
      time_lm  = pmin(time_raw, horizon_days),
      ARM = factor(ARM, levels = c("Control", "Steroids", "Combined",
                                   "Dual Therapy", "Other Rejection"))
    )
  
  n_zero <- sum(out$time_lm == 0)
  if (n_zero > 0) {
    message("  note: ", n_zero, " patient(s) have exactly 0 days of post-landmark follow-up")
  }
  out
}

df_lm_short <- build_landmark_surv(LANDMARK_DAY, LM_HORIZON_SHORT)
df_lm_long  <- build_landmark_surv(LANDMARK_DAY, LM_HORIZON_LONG)

# --- How much cohort did the landmark cost, and from which arm? -------------
# Worth looking at properly. If the Control arm loses a far larger share than
# the treated arms, that IS the immortal time bias, quantified -- those are the
# early deaths the old analysis was silently assigning to Control.
landmark_attrition <- assign_arm_at_landmark(LANDMARK_DAY) %>%
  left_join(df_survival %>% select(TRR_ID_CODE, PTIME), by = "TRR_ID_CODE") %>%
  group_by(ARM) %>%
  summarise(
    n_before_landmark = n(),
    n_at_landmark     = sum(!is.na(PTIME) & PTIME >= LANDMARK_DAY),
    n_lost            = n_before_landmark - n_at_landmark,
    pct_lost          = 100 * n_lost / n_before_landmark,
    .groups = "drop"
  )

landmark_attrition %>%
  gt() %>%
  fmt_number(columns = pct_lost, decimals = 1) %>%
  cols_label(
    ARM               = "Arm",
    n_before_landmark = "N assigned to arm",
    n_at_landmark     = paste0("N still observed at day ", round(LANDMARK_DAY)),
    n_lost            = "N excluded by landmark",
    pct_lost          = "% excluded"
  ) %>%
  tab_header(title = "Landmark Attrition by Arm") %>%
  tab_options(table.font.size = 13, data_row.padding = px(4),
              column_labels.font.weight = "bold") %>%
  tab_source_note("Patients excluded because they were no longer under observation at the landmark. A markedly higher exclusion rate in the Control arm is the immortal time bias made explicit: under the previous transplant-anchored design those deaths were counted against Control while every treated patient was guaranteed to have survived to their treatment date.")

#-------------------------------------------------------------------------------
# Step 5: KM plotting helper
#-------------------------------------------------------------------------------
# NOTE: the log-rank p-value is computed here and passed to ggsurvplot as a
# pre-formatted STRING rather than via pval = TRUE. survminer re-evaluates the
# model formula in the calling frame when asked to compute the p-value itself,
# which breaks when the data lives in a function-local variable. Computing it
# directly sidesteps that entirely.
plot_landmark_km <- function(df, arms_keep, horizon, break_by, title) {
  d <- df %>% filter(ARM %in% arms_keep) %>% mutate(ARM = droplevels(ARM))
  
  if (nlevels(d$ARM) < 2) {
    message("skipping plot -- fewer than 2 non-empty arms: ", title)
    return(invisible(NULL))
  }
  
  fit <- survfit(Surv(time_lm, event_lm) ~ ARM, data = d)
  
  sd_test  <- survdiff(Surv(time_lm, event_lm) ~ ARM, data = d)
  pv       <- 1 - pchisq(sd_test$chisq, length(sd_test$n) - 1)
  pval_lbl <- if (pv < 0.001) "log-rank p < 0.001" else sprintf("log-rank p = %.3f", pv)
  
  p <- ggsurvplot(
    fit,
    data          = d,
    pval          = pval_lbl,
    conf.int      = TRUE,
    risk.table    = TRUE,
    break.time.by = break_by,
    legend.title  = "Group",
    legend.labs   = levels(d$ARM),
    xlab          = paste0("Days since landmark (day ", round(LANDMARK_DAY), " post-transplant)"),
    ylab          = "Survival Probability",
    title         = title
  )
  fix_origin(p, break_by = break_by, max_time = horizon)
}

#-------------------------------------------------------------------------------
# Step 6: descriptive KM curves on the UNMATCHED landmark cohort
#-------------------------------------------------------------------------------
print(plot_landmark_km(
  df_lm_short, c("Steroids", "Combined", "Control"), LM_HORIZON_SHORT, 90,
  "Conditional Survival, Years 1-2 Post-Transplant (Landmark, Unmatched)"
))

print(plot_landmark_km(
  df_lm_long, c("Steroids", "Combined", "Control"), LM_HORIZON_LONG, 180,
  "Conditional Survival, Years 1-3 Post-Transplant (Landmark, Unmatched)"
))

print(plot_landmark_km(
  df_lm_long, c("Steroids", "Dual Therapy"), LM_HORIZON_LONG, 180,
  "Steroids vs Dual Therapy (Landmark, Unmatched)"
))

print(plot_landmark_km(
  df_lm_long, c("Dual Therapy", "Combined"), LM_HORIZON_LONG, 180,
  "Dual Therapy vs Combined (Landmark, Unmatched)"
))

# Survival probability at each horizon
fit_lm_3arm_short <- survfit(Surv(time_lm, event_lm) ~ ARM,
                             data = df_lm_short %>%
                               filter(ARM %in% c("Steroids","Combined","Control")) %>%
                               mutate(ARM = droplevels(ARM)))
summary(fit_lm_3arm_short, times = LM_HORIZON_SHORT)

fit_lm_3arm_long <- survfit(Surv(time_lm, event_lm) ~ ARM,
                            data = df_lm_long %>%
                              filter(ARM %in% c("Steroids","Combined","Control")) %>%
                              mutate(ARM = droplevels(ARM)))
summary(fit_lm_3arm_long, times = LM_HORIZON_LONG)

#-------------------------------------------------------------------------------
# Step 7: propensity matching WITHIN the landmark cohort
#-------------------------------------------------------------------------------
# Matching is redone here rather than reusing m_combined_steroid / m_combined_ctrl
# from the demographic section. Those were fit on the full year-1 cohort; if the
# landmark restriction were applied afterwards it would break matched pairs
# non-randomly (the patient who died at month 6 is dropped, their match is not),
# reintroducing the imbalance the matching existed to remove. Matching within
# the eligible cohort keeps pairs intact.
#
# Tables 2 and 3 earlier in the script therefore describe the YEAR-1 matched
# cohorts, while this section reports its own Ns and its own balance. Do not
# quote one table's N alongside the other's hazard ratio.
match_within_landmark <- function(df_lm, treat_arm, ctrl_arm, label, seed = 1234) {
  
  d <- df_lm %>%
    filter(ARM %in% c(treat_arm, ctrl_arm)) %>%
    mutate(treat = as.integer(ARM == treat_arm)) %>%
    left_join(baseline_covs, by = "TRR_ID_CODE")
  
  md <- d %>% select(TRR_ID_CODE, treat, all_of(match_covariates))
  report_complete_case_loss(md, label)                    # [FIX 9]
  
  md <- md %>%
    drop_na() %>%
    mutate(across(where(is.factor), droplevels))
  
  if (length(unique(md$treat)) < 2 || min(table(md$treat)) < 5) {
    message("skipping match -- too few complete cases in one arm: ", label)
    return(NULL)
  }
  
  set.seed(seed)
  m <- matchit(
    match_formula,
    data        = md,
    method      = "nearest",
    distance    = "logit",
    ratio       = 1,
    caliper     = 0.2,                                    # [FIX 10]
    std.caliper = TRUE
  )
  
  message("[", label, "] treated units unmatched by caliper: ",
          sum(m$treat == 1 & is.na(m$subclass)))
  
  matched_ids <- match.data(m)$TRR_ID_CODE
  
  list(
    matchit = m,
    data    = d %>%
      filter(TRR_ID_CODE %in% matched_ids) %>%
      mutate(ARM = droplevels(ARM))
  )
}

lm_match_steroid_combined <- match_within_landmark(
  df_lm_long, treat_arm = "Combined", ctrl_arm = "Steroids",
  label = "Landmark: Combined vs Steroid"
)

lm_match_combined_control <- match_within_landmark(
  df_lm_long, treat_arm = "Combined", ctrl_arm = "Control",
  label = "Landmark: Combined vs Control"
)

# --- Balance ---
if (!is.null(lm_match_steroid_combined)) {
  summary(lm_match_steroid_combined$matchit)
  print(love.plot(lm_match_steroid_combined$matchit,
                  binary = "std", stats = "mean.diffs", abs = TRUE,
                  var.order = "unadjusted", thresholds = c(m = 0.1),
                  title = "Landmark Cohort Balance: Combined vs Steroid",
                  sample.names = c("Unmatched", "Matched")))
}

if (!is.null(lm_match_combined_control)) {
  summary(lm_match_combined_control$matchit)
  print(love.plot(lm_match_combined_control$matchit,
                  binary = "std", stats = "mean.diffs", abs = TRUE,
                  var.order = "unadjusted", thresholds = c(m = 0.1),
                  title = "Landmark Cohort Balance: Combined vs Control",
                  sample.names = c("Unmatched", "Matched")))
}

