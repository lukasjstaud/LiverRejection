  ) %>%
  tab_header(title = "Table 4. Combined vs Steroid (Unmatched)") %>%
  tab_source_note("Values are n (%) or median (IQR) as indicated. P-values from Wilcoxon rank-sum (continuous), chi-square, or Fisher's exact tests (categorical, selected on expected cell counts) as appropriate. No propensity score matching applied.")

