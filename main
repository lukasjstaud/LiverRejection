rej_stats  <- calc_demo_stats(pat_combined_demo_table_m_steroid) #pat_combined_demo_table
ctrl_stats <- calc_demo_stats(pat_steroid_demo_table_m) #pat_steroid_demo_table

rej_std  <- calc_demo_std(rej_stats)
ctrl_std <- calc_demo_std(ctrl_stats)

num_rej  <- rej_stats$n
num_ctrl <- ctrl_stats$n

mean_rej  <- build_mean_vector(rej_stats)
mean_ctrl <- build_mean_vector(ctrl_stats)

