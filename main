#===============================================================================
# GTSUMMARY-STYLE TABLES  (replaces the hand-built gt() Table 1-5 blocks)
#
# This block reproduces the "LTA vs KALT" reference style:
#   - Column headers show "GroupName, N = n"
#   - Continuous vars: mean (SD)
#   - Categorical vars: n (%)
#   - Multi-level categorical vars get ONE p-value on the group header row,
#     not repeated on every sub-level
#   - Footnote 1: "Mean (SD); n (%)"
#   - Footnote 2: names of the tests actually used (t-test/Wilcoxon,
#     chi-square/Fisher, as applicable)
#
# It does NOT change any of your cohort-building code above (pat_rej_demo_table,
# pat_ctrl_demo_table, pat_combined_demo_table, etc. are used as-is). Paste this
# in place of the format_table1()...format_table5() + gt() blocks.
#-------------------------------------------------------------------------------


#-------------------------------------------------------------------------------
# Step 0: a shared "prep" function that derives the display-ready columns
# every table needs, from whatever demo table you feed it (pat_rej_demo_table,
# pat_ctrl_demo_table, pat_combined_demo_table, pat_steroid_demo_table, ...).
# This centralizes the same recodes calc_demo_stats() was doing by hand.
#-------------------------------------------------------------------------------
prep_gts_df <- function(df) {
  df %>%
    mutate(
      AGE   = as.numeric(AGE),
      MELD_PELD_LAB_SCORE = as.numeric(MELD_PELD_LAB_SCORE),
      COLD_ISCH = as.numeric(COLD_ISCH),
      GENDER_LBL = case_when(
        GENDER == "M" ~ "Male",
        GENDER == "F" ~ "Female",
        TRUE ~ NA_character_
      ),
      RACE_LBL = race_group(.),                       # reuses your existing helper
      DIAB_LBL = case_when(
        as.numeric(DIAB) %in% 2:5 ~ "Yes",
        as.numeric(DIAB) == 1     ~ "No",
        TRUE ~ NA_character_
      ),
      ORGAN_LBL = organ_group(.),                      # reuses your existing helper
      LIVING_DON_LBL = case_when(
        DON_TY == "L" ~ "Yes",
        !is.na(DON_TY) ~ "No",
        TRUE ~ NA_character_
      ),
      PREV_LIV_LBL = case_when(
        PREV_TX == "Y" ~ "Yes",
        !is.na(PREV_TX) ~ "No",
        TRUE ~ NA_character_
      ),
      PREV_ANY_LBL = ifelse(is.na(PREV_TX_ANY_N), "0", as.character(PREV_TX_ANY_N)),
      HLA_MM = factor(MM_TOTAL, levels = 0:6),
      PERFUSION_LBL = case_when(
        LI_MACHINE_PERFUSION == "Y" ~ "Yes",
        !is.na(LI_MACHINE_PERFUSION) ~ "No",
        TRUE ~ NA_character_
      ),
      PERFUSION_TY_LBL = case_when(
        LI_MACHINE_PERFUSION_TY == "1" ~ "Normothermic",
        LI_MACHINE_PERFUSION_TY == "2" ~ "Hypothermic",
        TRUE ~ NA_character_
      )
    )
}

# variables + labels shared by every table (order here = row order in the table)
gts_vars <- c("AGE", "GENDER_LBL", "RACE_LBL", "DIAB_LBL", "MELD_PELD_LAB_SCORE",
              "ORGAN_LBL", "LIVING_DON_LBL", "COLD_ISCH", "PREV_LIV_LBL",
              "PREV_ANY_LBL", "HLA_MM", "PERFUSION_LBL", "PERFUSION_TY_LBL")

gts_labels <- list(
  AGE               ~ "Recipient Age, y",
  GENDER_LBL        ~ "Sex, n (%)",
  RACE_LBL          ~ "Race/ethnicity, n (%)",
  DIAB_LBL          ~ "History of Diabetes, n (%)",
  MELD_PELD_LAB_SCORE ~ "MELD, mean (SD)",
  ORGAN_LBL         ~ "Organ Transplanted, n (%)",
  LIVING_DON_LBL    ~ "Living Donor, n (%)",
  COLD_ISCH         ~ "Cold Ischemic Time, hr",
  PREV_LIV_LBL      ~ "Previous Liver Transplant, n (%)",
  PREV_ANY_LBL      ~ "Previous Any Transplant, n (%)",
  HLA_MM            ~ "HLA Mismatch Level (0-6), n (%)",
  PERFUSION_LBL     ~ "Liver Perfusion Used, n (%)",
  PERFUSION_TY_LBL  ~ "Perfusion Type, n (%)"
)

#-------------------------------------------------------------------------------
# Step 1: generic 2-arm (or 3-arm) gtsummary table builder
#   group_col  : name of the grouping column, e.g. "REJ_GROUP"
#   group_lbls : named vector -> gtsummary header labels, e.g.
#                c(Combined = "Combined Therapy", Control = "No Rejection")
#-------------------------------------------------------------------------------
build_gts_table <- function(df_combined, group_col, group_lbls = NULL, caption = NULL) {
  
  d <- prep_gts_df(df_combined)
  
  tbl <- d %>%
    select(all_of(group_col), all_of(gts_vars)) %>%
    tbl_summary(
      by = all_of(group_col),
      label = gts_labels,
      statistic = list(
        all_continuous()  ~ "{mean} ({sd})",
        all_categorical() ~ "{n} ({p}%)"
      ),
      digits = list(all_continuous() ~ 1),
      missing = "no"
    ) %>%
    add_p(
      test = list(
        all_continuous() ~ "t.test"
        # all_categorical() intentionally left unspecified: gtsummary's default
        # categorical test already auto-switches between chisq.test and
        # fisher.test based on expected cell counts, so naming it explicitly
        # is unnecessary and "chisq.test.no.correction" is not a valid name.
      ),
      pvalue_fun = ~ style_pvalue(.x, digits = 3)
    ) %>%
    bold_labels() %>%
    modify_header(all_stat_cols() ~ "**{level}**, N = {n}") %>%
    modify_footnote(all_stat_cols() ~ "Mean (SD); n (%)") %>%
    modify_footnote(p.value ~ "Welch two-sample t-test; Pearson's Chi-squared test / Fisher's exact test")
  
  if (!is.null(group_lbls)) {
    for (lv in names(group_lbls)) {
      tbl <- tbl %>% modify_header(
        !!rlang::sym(paste0("stat_", which(levels(factor(d[[group_col]])) == lv))) :=
          paste0("**", group_lbls[[lv]], "**, N = {n}")
      )
    }
  }
  
  if (!is.null(caption)) tbl <- tbl %>% modify_caption(caption)
  
  tbl
}

#-------------------------------------------------------------------------------
# Step 2: assemble each table's combined data frame with a GROUP column, then
# call the builder. These mirror your Table 1 - Table 5 comparisons exactly.
#-------------------------------------------------------------------------------

## ---- Table 1: Rejection vs Rituxan vs Control (3-arm) ----------------------
tbl1_df <- bind_rows(
  pat_rej_demo_table    %>% mutate(REJ_GROUP = "Rejection"),
  pat_ritux_demo_table  %>% mutate(REJ_GROUP = "Rituxan"),
  pat_ctrl_demo_table   %>% mutate(REJ_GROUP = "Control")
) %>%
  mutate(REJ_GROUP = factor(REJ_GROUP, levels = c("Rejection", "Rituxan", "Control")))

gts_table1 <- build_gts_table(
  tbl1_df, "REJ_GROUP",
  caption = "**Table 1. Baseline Characteristics: Rejection vs. Rituxan vs. Control**"
)
gts_table1

