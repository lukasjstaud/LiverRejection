# Claude simplification of my manual calculation
# ------------------------------------------------------------------------
# Function 1: raw counts and medians
# ------------------------------------------------------------------------
calc_demo_stats <- function(df) {
  n_total <- nrow(df)
  
  race_wt    <- sum(df$ETHCAT == "1", na.rm = TRUE)
  race_bl    <- sum(df$ETHCAT == "2", na.rm = TRUE)
  race_his   <- sum(df$ETHCAT == "4", na.rm = TRUE)
  race_asia  <- sum(df$ETHCAT == "5", na.rm = TRUE)
  race_other <- n_total - sum(race_wt, race_bl, race_his, race_asia)
  
  txkid <- sum(df$TXKID %in% c("L","R","E"), na.rm = TRUE)
  txhrt <- sum(df$TXHRT == "Y", na.rm = TRUE)
  txlng <- sum(df$TXLNG %in% c("L","R","E"), na.rm = TRUE)
  txpan <- sum(df$TXPAN %in% c("L","R","E"), na.rm = TRUE)
  txliv <- n_total - sum(txkid, txhrt, txlng, txpan)
  
  list(
    n            = n_total,
    age_med      = median(df$AGE, na.rm = TRUE),
    age_q1       = quantile(df$AGE, 0.25, na.rm = TRUE),
    age_q3       = quantile(df$AGE, 0.75, na.rm = TRUE),
    gen_count    = sum(df$GENDER == "M", na.rm = TRUE),
    race_wt      = race_wt,
    race_bl      = race_bl,
    race_his     = race_his,
    race_asia    = race_asia,
    race_other   = race_other,
    meld_med     = median(df$MELD_PELD_LAB_SCORE, na.rm = TRUE),
    meld_q1      = quantile(df$MELD_PELD_LAB_SCORE, 0.25, na.rm = TRUE),
    meld_q3      = quantile(df$MELD_PELD_LAB_SCORE, 0.75, na.rm = TRUE),
    txliv        = txliv,
    txkid        = txkid,
    txhrt        = txhrt,
    txlng        = txlng,
    txpan        = txpan,
    liv_don      = sum(df$DON_TY == "L", na.rm = TRUE),
    cold_isch_med= median(df$COLD_ISCH, na.rm = TRUE),
    cold_isch_q1 = quantile(df$COLD_ISCH, 0.25, na.rm = TRUE),
    cold_isch_q3 = quantile(df$COLD_ISCH, 0.75, na.rm = TRUE),
    prev_liver   = sum(df$PREV_TX == "Y", na.rm = TRUE),
    prev_tx_0    = sum(is.na(df$PREV_TX_ANY_N)),
    prev_tx_1    = sum(df$PREV_TX_ANY_N == "1", na.rm = TRUE),
    prev_tx_2    = sum(df$PREV_TX_ANY_N == "2", na.rm = TRUE),
    prev_tx_3    = sum(df$PREV_TX_ANY_N == "3", na.rm = TRUE)
  )
}

# ------------------------------------------------------------------------
# Function 2: IQR strings + percentages, built FROM the stats list above
# (takes the output of calc_demo_stats, so no re-filtering of the df needed)
# ------------------------------------------------------------------------
calc_demo_std <- function(s) {
  pct <- function(count) 100 * count / s$n
  
  list(
    age_qstring   = paste0(" (", s$age_q1, "\u2013", s$age_q3, ")"),
    gen_perc      = pct(s$gen_count),
    race_wt_perc  = pct(s$race_wt),
    race_bl_perc  = pct(s$race_bl),
    race_his_perc = pct(s$race_his),
    race_asia_perc= pct(s$race_asia),
    race_other_perc = pct(s$race_other),
    meld_qstring  = paste0(" (", s$meld_q1, "\u2013", s$meld_q3, ")"),
    txliv_perc    = pct(s$txliv),
    txkid_perc    = pct(s$txkid),
    txhrt_perc    = pct(s$txhrt),
    txlng_perc    = pct(s$txlng),
    txpan_perc    = pct(s$txpan),
    liv_don_perc  = pct(s$liv_don / s$n),
    isch_qstring  = paste0(" (", s$cold_isch_q1, "\u2013", s$cold_isch_q3, ")"),
    prev_liv_perc = pct(s$prev_liver),
    prev_tx_0_perc = pct(s$prev_tx_0),
    prev_tx_1_perc = pct(s$prev_tx_1),
    prev_tx_2_perc = pct(s$prev_tx_2),
    prev_tx_3_perc = pct(s$prev_tx_3)
  )
}

# ------------------------------------------------------------------------
# Assemble the mean_* and std_* vectors in demo_label1 order
# ------------------------------------------------------------------------
build_mean_vector <- function(s) {
  c(
    s$n,
    s$age_med,
    s$gen_count,
    NA,
    s$race_wt, s$race_bl, s$race_his, s$race_asia, s$race_other,
    s$meld_med,
    NA,
    s$txliv, s$txkid, s$txhrt, s$txlng, s$txpan,
    s$liv_don,
    s$cold_isch_med,
    s$prev_liver,
    NA,
    s$prev_tx_0, s$prev_tx_1, s$prev_tx_2, s$prev_tx_3
  )
}

build_std_vector <- function(s, std) {
  c(
    NA,
    std$age_qstring,
    std$gen_perc,
    NA,
    std$race_wt_perc, std$race_bl_perc, std$race_his_perc, std$race_asia_perc, std$race_other_perc,
    std$meld_qstring,
    NA,
    std$txliv_perc, std$txkid_perc, std$txhrt_perc, std$txlng_perc, std$txpan_perc,
    std$liv_don_perc,
    std$isch_qstring,
    std$prev_liv_perc,
    NA,
    std$prev_tx_0_perc, std$prev_tx_1_perc, std$prev_tx_2_perc, std$prev_tx_3_perc
  )
}

# ------------------------------------------------------------------------
# Running Demographic Functions
# ------------------------------------------------------------------------
rej_stats  <- calc_demo_stats(pat_rej_demo_table)
ctrl_stats <- calc_demo_stats(pat_ctrl_demo_table)
ritux_stats <- calc_demo_stats(pat_ritux_demo_table)

rej_std  <- calc_demo_std(rej_stats)
ctrl_std <- calc_demo_std(ctrl_stats)
ritux_std <- calc_demo_std(ritux_stats)

num_rej  <- rej_stats$n
num_ctrl <- ctrl_stats$n
num_ritux <- ritux_stats$n

mean_rej  <- build_mean_vector(rej_stats)
mean_ctrl <- build_mean_vector(ctrl_stats)
mean_ritux <- build_mean_vector(ritux_stats)

std_rej  <- data.frame(std_rej  = build_std_vector(rej_stats, rej_std))
std_ctrl <- data.frame(std_ctrl = build_std_vector(ctrl_stats, ctrl_std))
std_ritux <- data.frame(std_ritux = build_std_vector(ritux_stats, ritux_std))

# ------------------------------------------------------------------------
