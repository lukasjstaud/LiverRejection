#-----------------------------------------------
# _____________________________________________________________________________
# creating filters of index data
# NOTE: loaded data is already filtered by 10 year date range at this point

# ---------------------------------------------------------------
# Filter1 - Age filter

col_age_range  <- "AGE"     # <- change to your column name
age_min <- 18            # <- change to the value you want 
age_max <- 80         # <- change to the value you want

df_liver_data$AGE <- as.numeric(df_liver_data$AGE)

df_liver_data_filtered <- df_liver_data %>%
  filter(.data[[col_age_range]] >= age_min & .data[[col_age_range]] <= age_max)  # filters the age

# ---------------------------------------------------------------
#  Filter2 - Data Dates: Filter out Patients w. TX before 03APR2015 and after 03APR2025
# 
FILTER_DATE_COL_FOL <- "PX_STAT_DATE_FOL" # column for follow up data
FILTER_DATE_COL_TX <- "TX_DATE"

tx_start_date <- "2015-04-03"
tx_end_date <- "2025-04-03"

df_liver_data_filtered <- df_liver_data_filtered %>%
  filter(.data[[FILTER_DATE_COL_TX]] >= tx_start_date & .data[[FILTER_DATE_COL_TX]] <= tx_end_date)

#--------------------------------------------------------------
# Filter* - Filtering of dfs base on the above criteria

tx_ids_to_keep <- df_liver_data_filtered$TRR_ID_CODE
dnr_ids_to_keep <- df_liver_data_filtered$DONOR_ID

df_immuno_induc <- df_immuno_induc %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_liver_fol_fil <- df_liver_fol %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_immuno_fol <- df_immuno_fol_read %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_deceased_don_fil <- df_deceased_don%>% 
  filter(DONOR_ID %in% dnr_ids_to_keep)

df_hla_fil <- df_hla %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)
  
df_pra_fil <- df_pra %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

# need to load living donor data

# ______________________________________________________________________________
# Parsing liver_data filtered into respective groups: rejection vs no rejection - currently not in use

# ______________________________________________________________________________
# Merging look up table with liver_date to compare No Rejection, 6 month, 12 month 

# Merging table
df_immuno_fol <- df_immuno_fol %>%
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, TX_DATE, DISCHARGE_DATE, TRTREJ6M, TRTREJ1Y, TX_DATE), by = "TRR_ID_CODE") %>%
  filter(!is.na(TX_DATE)) # very important filter!!, removes any immuno_fol row
# that had tx prior to the date ranges specified by uploaded data_liver file

# ------------------------------------------------
# Filtering out follow up dates +1 year

df_immuno_fol <- df_immuno_fol %>% # telling R to treat columns as a date and sort
  mutate(
    PX_STAT_DATE_FOL = as.Date(PX_STAT_DATE_FOL),
    TX_DATE = as.Date(TX_DATE)
  ) %>% # sets csv values in these columns as date data types
  mutate(FOL_DATE_DAYS_DELTA = time_length(interval(TX_DATE, PX_STAT_DATE_FOL), "days")) %>% # new column with post op days
  filter(abs(FOL_DATE_DAYS_DELTA) < 365.24219) %>% # filters for follow ups + 1 year
  arrange(PX_STAT_DATE_FOL) # orders based on follow up date

#_________________________________________________________________________________
# Counting Anti-rejection therapy at set times
# 
# set search columns
# GENERICMMF, GENERICTACROLIMUS, ASTAGRAFXL, NULOJIX are a maintenance column ONLY
RX_COLS <- c("ALG", "CYCLOSPORIN", "OKT4", "CYTOXAN", "METHOTREXATE", "BREQUINARSODIUM", "MIZORIBINE",
             "ATGAM", "NRATGNRATS", "OKT3", "XOMAZYMECD5", "DAB486IL2", "ANTILFA1", "ANTIICAM1",
             "IL1RECEPTORANTAGONIST", "ANTIIL6", "ANTITNF", "SOLUBLEIL1RECEPTOR", "ALDESLEUKIN", "T10B9",
             "SANDIMMUNE", "DEOXYSPERGUALIN", "NEORAL", "SANGCYA", "THYMOGLOBULIN", "ZENAPAX",
             "SIMULECT", "GENGRAF", "ZORTRESS", "EON", "MYFORTIC", "GENERICCYCLOSPORIN", "STEROIDS", "PROGRAF",
             "CAMPATH", "FTY720","RITUXAN", "GENERICMYFORTIC", "GENERICSIROLIMUS", "ENVARSUSXR", "RAPAMUNE",
             "LEFLUNOMIDE", "IMURAN", "CELLCEPT") # important to note this does not capture the "other drug" column

COL_TAIL <- "_ANTIREJ" # this needs to change based on if we are looking at induction, maintenance, ANTI-reject

COLS_TO_CHECK <- paste0(RX_COLS, COL_TAIL)

# -------------------------------------------------------------
# Collecting TRR_CODE of patients that used Rituxan in anti-rejection therapy

# During in patient stay
rituxan_id_disc_vect <- df_immuno_induc %>%
  filter(RITUXAN_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

# At follow up filtered by patients that had Rituxan administered during inpatient sp tx
rituxan_id_fol_vect <- df_immuno_fol %>% 
  filter(RITUXAN_ANTIREJ == 1) %>% 
  filter(!(TRR_ID_CODE %in% rituxan_id_disc_vect)) %>% 
  pull(TRR_ID_CODE)
  
rituxan_id_all_vect <- c(rituxan_id_disc_vect, rituxan_id_fol_vect)

#--------------------------------------------------------------------------------------------------
# Creating running counts of follow up treatments for anti-rejection therapy and checking for combo therapy

# Below commented out bc it takes so damn long to run
df_immuno_fol <- df_immuno_fol %>%
  # running count
  mutate(REJECT_RUNNING_COUNT = 0L) %>%
  group_by(TRR_ID_CODE) %>%
  mutate(
    REJECT_RUNNING_COUNT = cumsum(if_any(all_of(COLS_TO_CHECK), ~ !is.na(.) & . == 1))
  ) %>%
  ungroup() %>%
  # combo therapy rx'ed?
  mutate(NUM_ANTI_REJ_RXED = 0L) |>
  mutate(NUM_ANTI_REJ_RXED = rowSums(across(all_of(COLS_TO_CHECK)) == 1, na.rm = TRUE))

# store data so that I dont have to keep calculating it
df_immuno_fol_calc <- df_immuno_fol



#-----------------------------------------------------------------------------------------------------
# Actually counting number of instances within set time

# extracting data from df_immuno_fol
freq_drug_fol_antirej_indiv <- data.frame(
  drug_name      = str_remove(COLS_TO_CHECK, COL_TAIL),
  drug_count  = sapply(df_immuno_fol[COLS_TO_CHECK], function(x) sum(x == 1, na.rm = TRUE)),
  rej6m_count = sapply(COLS_TO_CHECK, function(col) {
    sum(df_immuno_fol[[col]] == 1 & df_immuno_fol$FOL_DATE_DAYS_DELTA <= 182.62110, na.rm = TRUE)
  }),
  rej1y_count = sapply(COLS_TO_CHECK, function(col) {
    sum(df_immuno_fol[[col]] == 1 & df_immuno_fol$FOL_DATE_DAYS_DELTA <= 365.24219, na.rm = TRUE)
  })
)

#_________________________________________________________________________________
# Setting count for Anti-Rej Therapy during inpatient s/p tx
# * will need to combine in patient and follow up data
# GENERICMMF, GENERICTACROLIMUS, ASTAGRAFXL, NULOJIX are a maintenance column ONLY

# df_immuno_induc <- df_immuno_induc |> 
