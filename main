  race_other_rej_count,  # 8  Other/Multiracial
  meld_rej_med,          # 9  MELD
  NA,                    # 10 "Organ Transplanted, n(%)" header
  txliv_rej_count,       # 11 Liver
  txkid_rej_count,       # 12 Liver and Kidney
  txhrt_rej_count,       # 13 Liver and Heart
  txlng_rej_count,       # 14 Liver and Lung
  txpan_rej_count,       # 15 Liver and Pancreas
