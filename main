    N_with_yr2_followup = "N with Yr2 Follow-up",
    N_rejected_yr2      = "N Treated for Rejection in Yr2",
    Pct_rejected_yr2     = "% Treated in Yr2"
  ) %>%
  tab_header(title = "Anti-Rejection Treatment During Year 2, by First-Year Treatment Group") %>%
  tab_options(
    table.font.size = 13,
    data_row.padding = px(4),
    column_labels.font.weight = "bold"
  ) %>%
  tab_source_note("Landmark cohort restricted to patients with PTIME >= 365.25 days (still followed at 1 year). Year 2 defined as day 365.25-730.5 post-transplant.")

