#------------------------------------------
# Demographic Table 3 (Combined Therapy / No Rejection)
format_table3 <- function() {
  tbl_data %>%
    filter(demo_label1 != "n") %>%
    mutate(
      is_header = is.na(ref_value1) & is.na(std_rej),
      is_median = str_detect(demo_label1, "median\\(IQR\\)") |
        (!is_header & str_detect(std_rej, "^\\(")),
      mean_rej_fmt  = if_else(is_median, NA_character_,
                              format(round(mean_rej), big.mark = ",", scientific = FALSE)),
      mean_ctrl_fmt = if_else(is_median, NA_character_,
                              format(round(mean_ctrl), big.mark = ",", scientific = FALSE)),
      `Combined Therapy` = case_when(
        is_header ~ NA_character_,
        demo_label1 == "n" ~ mean_rej_fmt,
        is_median ~ paste0(format(mean_rej, big.mark = ","), " ", std_rej),
        TRUE ~ paste0(mean_rej_fmt,
                      " (", sprintf("%.1f", as.numeric(std_rej)), "%)")
      ),
      `No Rejection` = case_when(
        is_header ~ NA_character_,
        demo_label1 == "n" ~ mean_ctrl_fmt,
        is_median ~ paste0(format(mean_ctrl, big.mark = ","), " ", std_ctrl),
        TRUE ~ paste0(mean_ctrl_fmt,
                      " (", sprintf("%.1f", as.numeric(std_ctrl)), "%)")
      ),
      `P value` = case_when(
        is.na(pval_combined_norej) ~ NA_character_,
        pval_combined_norej < 0.001 ~ "<0.001",
        TRUE ~ sprintf("%.3f", pval_combined_norej)
      ),
      Variable = if_else(is_header, demo_label1,
                         paste0("    ", demo_label1))
    ) %>%
    select(Variable, `Combined Therapy`, `No Rejection`, `P value`, is_header)
}

demo_tbl3 <- format_table3()

