#===============================================================================
# [FIX 19] Drug column definitions MOVED UP so the 0/1 indicator columns can be
# coerced to numeric immediately after reading. If any of these columns come in
# as character (a stray "Y"/"N", a quoted "1", a blank-padded field), then
# `rowSums(across(...) == 1)` silently evaluates to 0 for that whole column and
# the drug looks like it was never prescribed. Coercing once, at the source,
# removes that failure mode for every downstream section.
#-------------------------------------------------------------------------------
# GENERICMMF, GENERICTACROLIMUS, ASTAGRAFXL, NULOJIX are a maintenance column ONLY
RX_COLS <- c("ALG", "CYCLOSPORIN", "OKT4", "CYTOXAN", "METHOTREXATE", "BREQUINARSODIUM", "MIZORIBINE",
             "ATGAM", "NRATGNRATS", "OKT3", "XOMAZYMECD5", "DAB486IL2", "ANTILFA1", "ANTIICAM1",
             "IL1RECEPTORANTAGONIST", "ANTIIL6", "ANTITNF", "SOLUBLEIL1RECEPTOR", "ALDESLEUKIN", "T10B9",
             "SANDIMMUNE", "DEOXYSPERGUALIN", "NEORAL", "SANGCYA", "THYMOGLOBULIN", "ZENAPAX",
             "SIMULECT", "GENGRAF", "ZORTRESS", "EON", "MYFORTIC", "GENERICCYCLOSPORIN", "STEROIDS", "PROGRAF",
             "CAMPATH", "FTY720","RITUXAN", "GENERICMYFORTIC", "GENERICSIROLIMUS", "ENVARSUSXR", "RAPAMUNE",
             "LEFLUNOMIDE", "IMURAN", "CELLCEPT") # important to note this does not capture the "other drug" column

COL_TAIL <- "_ANTIREJ" # this needs to change based on if we are looking at induction, maintenance, ANTI-reject

COLS_TO_CHECK <- paste0(RX_COLS, COL_TAIL)

# [FIX 19] Coerce drug indicator columns to numeric. any_of() so a missing
# column is skipped rather than erroring.
coerce_rx_numeric <- function(df) {
  df %>% mutate(across(any_of(COLS_TO_CHECK), ~ suppressWarnings(as.numeric(.x))))
}

df_immuno_fol_read <- coerce_rx_numeric(df_immuno_fol_read)
df_immuno_induc    <- coerce_rx_numeric(df_immuno_induc)

# [FIX 19] Report any drug column that failed to coerce anywhere (all-NA after
# coercion when it had content before) -- a fast way to catch an encoding change.
rx_all_na <- names(which(sapply(
  intersect(COLS_TO_CHECK, names(df_immuno_fol_read)),
  function(cn) all(is.na(df_immuno_fol_read[[cn]]))
)))
if (length(rx_all_na)) {
  message("Drug columns entirely NA after numeric coercion (check source encoding): ",
          paste(rx_all_na, collapse = ", "))
}

# [FIX 19] Numeric coercion for the continuous recipient variables used in
# medians, matching, and Cox/logistic models. Same rationale.
df_liver_data <- df_liver_data %>%
  mutate(across(any_of(c("AGE", "MELD_PELD_LAB_SCORE", "COLD_ISCH", "PTIME")),
                ~ suppressWarnings(as.numeric(.x))))

#-----------------------------------------------
# ===============================================================================
# Filters of index data
#------------------------------------------------------------------------
# ---------------------------------------------------------------
# Filter1 - Age filter

col_age_range  <- "AGE"     # <- change to your column name
age_min <- 18            # <- change to the value you want 
age_max <- 80         # <- change to the value you want

df_liver_data$AGE <- as.numeric(df_liver_data$AGE)

df_liver_data_filtered <- df_liver_data %>%
  filter(.data[[col_age_range]] >= age_min & .data[[col_age_range]] <= age_max)  # filters the age

# ---------------------------------------------------------------
#  Filter2 - Data Dates: Filter out Patients w. TX before 03APR2015 and after 03APR2025
# 
FILTER_DATE_COL_FOL <- "PX_STAT_DATE_FOL" # column for follow up data
FILTER_DATE_COL_TX <- "TX_DATE"

tx_start_date <- "2015-04-03"
tx_end_date <- "2025-04-03"

df_liver_data_filtered <- df_liver_data_filtered %>%
  filter(.data[[FILTER_DATE_COL_TX]] >= tx_start_date & .data[[FILTER_DATE_COL_TX]] <= tx_end_date)

#--------------------------------------------------------------
# Filter* - Filtering of dfs base on the above criteria

tx_ids_to_keep <- df_liver_data_filtered$TRR_ID_CODE
dnr_ids_to_keep <- df_liver_data_filtered$DONOR_ID

df_immuno_induc <- df_immuno_induc %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_liver_fol_fil <- df_liver_fol %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_immuno_fol <- df_immuno_fol_read %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_deceased_don_fil <- df_deceased_don%>% 
  filter(DONOR_ID %in% dnr_ids_to_keep)

df_hla_fil <- df_hla %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

df_pra_fil <- df_pra %>% 
  filter(TRR_ID_CODE %in% tx_ids_to_keep)

# still need to load living donor data

# ______________________________________________________________________________
# Merging look up table with liver_date to compare No Rejection, 6 month, 12 month 

# [FIX 18] TX_DATE was listed twice in this select(); duplicate removed.
df_immuno_fol <- df_immuno_fol %>%
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, TX_DATE, DISCHARGE_DATE, TRTREJ6M, TRTREJ1Y), by = "TRR_ID_CODE") %>%
  filter(!is.na(TX_DATE)) # very important filter!!, removes any immuno_fol row
# that had tx prior to the date ranges specified by uploaded data_liver file

# ------------------------------------------------
# Filtering out follow up dates +1 year

df_immuno_fol <- df_immuno_fol %>% # telling R to treat columns as a date and sort
  mutate(
    PX_STAT_DATE_FOL = as.Date(PX_STAT_DATE_FOL),
    TX_DATE = as.Date(TX_DATE)
  ) %>% # sets csv values in these columns as date data types
  mutate(FOL_DATE_DAYS_DELTA = time_length(interval(TX_DATE, PX_STAT_DATE_FOL), "days")) %>% # new column with post op days
  filter(FOL_DATE_DAYS_DELTA >= 0 & FOL_DATE_DAYS_DELTA < 365.24219) %>% # filters for follow ups + 1 year
  arrange(PX_STAT_DATE_FOL) # orders based on follow up date

#--------------------------------------------------------------------------------------------------
# Creating running counts of follow up treatments for anti-rejection therapy and checking for combo therapy

df_immuno_fol <- df_immuno_fol %>%
  # running count
  mutate(REJECT_RUNNING_COUNT = 0L) %>%
  group_by(TRR_ID_CODE) %>%
  mutate(
    REJECT_RUNNING_COUNT = cumsum(if_any(all_of(COLS_TO_CHECK), ~ !is.na(.) & . == 1))
  ) %>%
  ungroup() %>%
  # combo therapy rx'ed?
  mutate(NUM_ANTI_REJ_RXED = 0L) |>
  mutate(NUM_ANTI_REJ_RXED = rowSums(across(all_of(COLS_TO_CHECK)) == 1, na.rm = TRUE))


# store data so that I dont have to keep calculating it
df_immuno_fol_calc <- df_immuno_fol

#-----------------------------------------------------------------------------------------------------
# Actually counting number of instances within set time

# extracting data from df_immuno_fol
freq_drug_fol_antirej_indiv <- data.frame(
  drug_name      = str_remove(COLS_TO_CHECK, COL_TAIL),
  drug_count  = sapply(df_immuno_fol[COLS_TO_CHECK], function(x) sum(x == 1, na.rm = TRUE)),
  rej6m_count = sapply(COLS_TO_CHECK, function(col) {
    sum(df_immuno_fol[[col]] == 1 & df_immuno_fol$FOL_DATE_DAYS_DELTA <= 182.62110, na.rm = TRUE)
  }),
  rej1y_count = sapply(COLS_TO_CHECK, function(col) {
    sum(df_immuno_fol[[col]] == 1 & df_immuno_fol$FOL_DATE_DAYS_DELTA <= 365.24219, na.rm = TRUE)
  })
)

#_________________________________________________________________________________
# Setting count for Anti-Rej Therapy during inpatient s/p tx
# * will need to combine in patient and follow up data

df_immuno_induc <- df_immuno_induc |> 
  semi_join(df_liver_data_filtered, by = "TRR_ID_CODE") |> 
  mutate(NUM_ANTI_REJ_RXED = 0L) |> 
  mutate(NUM_ANTI_REJ_RXED = rowSums(across(all_of(COLS_TO_CHECK)) == 1, na.rm = TRUE)) |> 
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, TX_DATE, DISCHARGE_DATE, DEATH_DATE), by = "TRR_ID_CODE") |> 
  arrange(TX_DATE) |> 
  mutate(DAYS_HOSP_SP_TX = 0L) |> 
  mutate(
    DISCHARGE_DATE = as.Date(DISCHARGE_DATE),
    TX_DATE = as.Date(TX_DATE)
  ) %>%
  mutate(DAYS_HOSP_SP_TX = time_length(interval(TX_DATE, DISCHARGE_DATE), "days"))

#_______________________________________________________________________________
# Parsing Tables

#-------------------------------------------------------------------------------
# Parsing by Anti-rejection and No rejection through 1 year

# Creating an array of patients with anti-rejection during inpatient sp tx
# [FIX 17] all_of() around COLS_TO_CHECK (bare external vector in select() is
#          deprecated tidyselect).
# [FIX 5]  distinct() here so a duplicated discharge record can't later cause
#          the patient to be DELETED outright by the n() > 1 filter.
pat_rej_array_dis <- df_immuno_induc %>% 
  filter(NUM_ANTI_REJ_RXED >= 1) %>% 
  mutate(DISCHARGE_DATE = as.Date(DISCHARGE_DATE)) %>% 
  select(TRR_ID_CODE, TX_DATE, DISCHARGE_DATE, NUM_ANTI_REJ_RXED, all_of(COLS_TO_CHECK)) %>%
  distinct(TRR_ID_CODE, .keep_all = TRUE)

#Pulling patient IDs treated inpatient post tx to then add to follow up
inpatient_reject_ID_vect <- pat_rej_array_dis |> 
  pull(TRR_ID_CODE)

# Isolating Patients with first instance of rejection in 1 year
# [FIX 17] all_of()
pat_rej_array_fol <- df_immuno_fol_calc %>%
  mutate(
    REJECT_RUNNING_COUNT = if_else(
      TRR_ID_CODE %in% inpatient_reject_ID_vect,
      REJECT_RUNNING_COUNT + 1,
      REJECT_RUNNING_COUNT
    )
  ) |> 
  filter(REJECT_RUNNING_COUNT == 1, NUM_ANTI_REJ_RXED >= 1) %>%
  group_by(TRR_ID_CODE) %>%
  slice_min(order_by = PX_STAT_DATE_FOL, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(
    TRR_ID_CODE, TRR_FOL_ID_CODE, TX_DATE, DISCHARGE_DATE, PX_STAT_DATE_FOL,
    FOL_DATE_DAYS_DELTA, REJECT_RUNNING_COUNT, NUM_ANTI_REJ_RXED, 
    all_of(COLS_TO_CHECK)
  ) %>%
  mutate(
    DISCHARGE_DATE = as.Date(DISCHARGE_DATE)
  )

# Combining Discharge and follow up rejections 
# [FIX 5] source coerced to integer so slice_min() below orders it numerically
#         (1 = discharge event, 2 = follow-up event).
pat_rej_array <- bind_rows(pat_rej_array_dis, pat_rej_array_fol, .id = "source") %>%
  mutate(source = as.integer(source))

# [FIX 4] Rejector IDs defined ONCE, from the combined rejection array, and used
# to define the control cohort by exclusion. Previously pat_ctrl_array used a
# row-wise REJECT_RUNNING_COUNT == 0 filter, which retained rows from patients
# who were rejection-free early but treated later in year 1 -- so ctrl_id_vect
# (pulled from that array) was contaminated with year-1 rejectors even though
# pat_ctrl_demo_table separately cleaned itself up. ctrl_id_vect feeds the
# year-2 landmark analyses, so the contamination propagated there.
rejector_ids <- unique(pat_rej_array$TRR_ID_CODE)

# Isolating patients w/o rejection at follow ups at 1 year
# [FIX 4] exclusion added; [FIX 17] all_of()
pat_ctrl_array <- df_immuno_fol_calc %>% 
  filter(!TRR_ID_CODE %in% rejector_ids) %>%
  filter(REJECT_RUNNING_COUNT == 0) %>%   # now redundant, kept as belt-and-braces
  select(
    TRR_ID_CODE, TRR_FOL_ID_CODE, TX_DATE, DISCHARGE_DATE, PX_STAT_DATE_FOL, 
    FOL_DATE_DAYS_DELTA, REJECT_RUNNING_COUNT, NUM_ANTI_REJ_RXED, all_of(COLS_TO_CHECK)
  ) %>% 
  mutate(FOLLOW_UP_NUM = 1L) |>
  group_by(TRR_ID_CODE) %>%
  slice_max(order_by = PX_STAT_DATE_FOL, n = 1, with_ties = FALSE) %>%
  ungroup()

# NOTE (unchanged behaviour, flagged for awareness): patients with NO follow-up
# rows at all never enter df_immuno_fol and are therefore neither cases nor
# controls. If that group is large, "no rejection" is partly "no data".
message("Patients in cohort with no year-1 follow-up rows: ",
        length(setdiff(tx_ids_to_keep,
                       union(rejector_ids, pat_ctrl_array$TRR_ID_CODE))))

# ==============================================================================
# Creating my groups
#-------------------------------------------------------------------------------
# Filtering for monotherapy
monotherapy_reject <- pat_rej_array |> 
  filter(NUM_ANTI_REJ_RXED < 2)

# -----------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used Rituxan ONLY in anti-rejection therapy

rituxan_id_all_vect <- monotherapy_reject %>%
  filter(RITUXAN_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

#--------------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used Steroids ONLY in anti-rejection therapy

steroid_id_all_vect <- monotherapy_reject %>%
  filter(STEROIDS_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

#--------------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used Thymoglobulin ONLY in anti-rejection therapy

thymo_id_all_vect <- monotherapy_reject %>%
  filter(THYMOGLOBULIN_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

#--------------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used SIMULECT ONLY in anti-rejection therapy

simulect_id_all_vect <- monotherapy_reject %>%
  filter(SIMULECT_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

#------------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used STEROID + Combo Therapy in anti-rejection therapy

dual_therapy_id_vect <- pat_rej_array %>%
  filter(STEROIDS_ANTIREJ == 1) %>%
  filter(SIMULECT_ANTIREJ == 1 | THYMOGLOBULIN_ANTIREJ == 1 | RITUXAN_ANTIREJ == 1) |> 
  pull(TRR_ID_CODE)

#------------------------------------------------------------------------------
# Collecting TRR_CODE of patients that used Rituxan ANY in anti-rejection therapy

rituxan_any_id_vect <- pat_rej_array %>%
  filter(RITUXAN_ANTIREJ == 1) %>%
  pull(TRR_ID_CODE)

#------------------------------------------------------------------------------
# Creating the combined arm for comparison
arm2_ID_vect <- unique(c(simulect_id_all_vect, thymo_id_all_vect, rituxan_id_all_vect))

#--------------------------------------------------------------------------------
# Collecting TRR_CODE of control patients that were NEVER treated for anti-rejection therapy
# [FIX 4] now drawn from the cleaned control array
ctrl_id_vect <- pat_ctrl_array %>%
  pull(TRR_ID_CODE)

# [FIX 4] sanity checks -- both should now be character(0) / integer(0)
stopifnot(length(intersect(arm2_ID_vect, ctrl_id_vect)) == 0)
stopifnot(length(intersect(steroid_id_all_vect, ctrl_id_vect)) == 0)

# =============================================================================
# HLA MISMATCH CALCULATION (A, B, DR loci) — 0 to 6 scale
#------------------------------------------------------------------------------

# --- Step 1: Use retyped donor HLA if available, else original typing ---
df_hla_fil <- df_hla_fil %>%
  mutate(
    DA1_final  = coalesce(RT_DA1, DA1),
    DA2_final  = coalesce(RT_DA2, DA2),
    DB1_final  = coalesce(RT_DB1, DB1),
    DB2_final  = coalesce(RT_DB2, DB2),
    DDR1_final = coalesce(RT_DDR1, DDR1),
    DDR2_final = coalesce(RT_DDR2, DDR2)
  )

# --- Step 2: Function to calculate mismatch at a single locus ---
locus_mismatch <- function(r1, r2, d1, d2) {
  # Returns NA if any of the 4 alleles are missing
  if (any(is.na(c(r1, r2, d1, d2)))) return(NA_integer_)
  rec_alleles <- c(r1, r2)
  don_alleles <- c(d1, d2)
  sum(!don_alleles %in% rec_alleles)
}

# --- Step 3: Apply row-wise to compute mismatch per locus + total ---
df_hla_calc <- df_hla_fil %>%
  rowwise() %>%
  mutate(
    MM_A     = locus_mismatch(RA1, RA2, DA1_final, DA2_final),
    MM_B     = locus_mismatch(RB1, RB2, DB1_final, DB2_final),
    MM_DR    = locus_mismatch(RDR1, RDR2, DDR1_final, DDR2_final),
    MM_TOTAL = if_else(
      any(is.na(c(MM_A, MM_B, MM_DR))),
      NA_integer_,
      MM_A + MM_B + MM_DR
    )
  ) %>%
  ungroup() %>% 
  select(TRR_ID_CODE, MM_A, MM_B, MM_DR, MM_TOTAL) |> 
  distinct(TRR_ID_CODE, .keep_all = TRUE)

#===============================================================================
# Processing PRA Data
#------------------------------------------------------------------------------- 
# CANNOT DO, physcians/centers stopped reporting PRA around mid-March 2015 :(

#===============================================================================
# Processing Deceased Donor Data
#------------------------------------------------------------------------------
# [FIX 7] A single donor can map to more than one recipient (split liver), and
# df_deceased_don itself contained duplicate DONOR_IDs (see the debug line that
# used to sit at the bottom of the script). Either produces duplicated rows here,
# which then multiply pat_rej_demo_table / pat_ctrl_demo_table on the next join
# and silently inflate every count in Table 1. distinct() on the recipient key
# after the join, mirroring what df_hla_calc already does.

df_deceased_don_fil2 <- df_deceased_don_fil %>% 
  left_join(df_liver_data_filtered |> 
              select(DONOR_ID, TRR_ID_CODE), by = "DONOR_ID") |> 
  select(TRR_ID_CODE, AGE_DON, LI_MACHINE_PERFUSION, LI_MACHINE_PERFUSION_TY, LI_FIBROSIS, NON_HRT_DON) |> 
  filter(!is.na(TRR_ID_CODE)) |> 
  distinct(TRR_ID_CODE, .keep_all = TRUE)

# =============================================================================
# Graphing
#---------------------------------------------------------------------------
# Prepping Table for graphing

freq_long <- freq_drug_fol_antirej_indiv %>%
  pivot_longer(
    cols = c(rej6m_count, rej1y_count),
    names_to = "rej_period",
    values_to = "rej_count"
  ) %>%
  mutate(
    rej_period = recode(rej_period,
                        "rej6m_count" = "6-Month",
                        "rej1y_count" = "1-Year")
  )

#===============================================================================
# Tables
#------------------------------------------------------------------------
# Collecting Demographic Data on the Reject vs Control Patients
#-------------------------------
# Rejection Demographic Table Building
# [FIX 5] The old `filter(!(source == 1 & n() > 1))` DELETED a patient entirely
# whenever they had two source==1 rows (both rows satisfy the condition), rather
# than deduplicating them. Replaced with slice_min(source), which keeps exactly
# one row per patient and prefers the earlier (discharge) event -- the correct
# choice for a first-rejection cohort.
pat_rej_demo_table <- pat_rej_array %>% 
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, AGE, GENDER, ETHCAT, MELD_PELD_LAB_SCORE, TXKID, TXHRT, TXLNG, TXPAN, 
                     PREV_TX, PREV_TX_ANY_N, DON_TY, COLD_ISCH, DIAB), by = "TRR_ID_CODE") |> 
  group_by(TRR_ID_CODE) %>%
  slice_min(order_by = source, n = 1, with_ties = FALSE) %>%
  ungroup() %>% 
  mutate(REJ_STAT = 1L) |> # for the following merge this will let me know what is a rejection pt
  left_join(df_deceased_don_fil2, by = "TRR_ID_CODE") |> # adding deceased donor table
  left_join(df_hla_calc, by = "TRR_ID_CODE") # adding HLA data

# Control Demographic Table Building
pat_ctrl_demo_table <- pat_ctrl_array %>% 
  left_join(df_liver_data_filtered %>% 
              select(TRR_ID_CODE, AGE, GENDER, ETHCAT, MELD_PELD_LAB_SCORE, TXKID, TXHRT, TXLNG, TXPAN, 
                     PREV_TX, PREV_TX_ANY_N, DON_TY, COLD_ISCH, DIAB), by = "TRR_ID_CODE") |> 
  mutate(DISCHARGE_DATE = as.Date(DISCHARGE_DATE)) %>% 
  mutate(REJ_STAT = 0L) %>% # for the following merge this will let me know what is a nonrejection pt
  filter(!TRR_ID_CODE %in% pat_rej_demo_table$TRR_ID_CODE) |>  # now redundant post-[FIX 4], kept defensively
  left_join(df_deceased_don_fil2, by = "TRR_ID_CODE") |> # adding deceased donor table
  left_join(df_hla_calc, by = "TRR_ID_CODE")

# [FIX 18] full_join() with no `by =` was joining on every shared column; the two
# tables also carry different columns (source vs FOLLOW_UP_NUM). bind_rows() is
# what was actually meant -- stack the two cohorts.
pat_all_demo_table <- bind_rows(pat_rej_demo_table, pat_ctrl_demo_table)

# Rituxan Demographic Table Building
pat_ritux_demo_table <- pat_rej_demo_table %>% 
  filter(TRR_ID_CODE %in% rituxan_any_id_vect)

# Steroid Demographic Table Building
pat_steroid_demo_table <- pat_rej_demo_table |> 
  filter(TRR_ID_CODE %in% steroid_id_all_vect)

# Combined Arm Demographic Table Building
