love.plot(
  m_combined_steroid,
  binary   = "std",
  stats    = "mean.diffs",
  abs      = TRUE,
  var.order = "unadjusted",
  thresholds = c(m = 0.1),
  title    = "Covariate Balance: Combined vs Steroid",
  sample.names = c("Unmatched", "Matched")
)

love.plot(
  m_combined_ctrl,
  binary   = "std",
  stats    = "mean.diffs",
  abs      = TRUE,
  var.order = "unadjusted",
  thresholds = c(m = 0.1),
  title    = "Covariate Balance: Combined vs Control",
  sample.names = c("Unmatched", "Matched")
)

