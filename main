# Survival Plots 
#-------------------------------------------------------------------------------
df_survival <- df_liver_data_filtered |> 
  select(TRR_ID_CODE, TX_DATE, COMPOSITE_DEATH_DATE, RETXDATE, PTIME, PX_STAT, PX_STAT_DATE) |> 
  mutate(ONE_YEAR_TX_SURV = case_when(
    PTIME >= 365.25 ~ 1,
    PTIME < 365.25 ~ 0
  )) |> 
  mutate(TWO_YEAR_TX_SURV = case_when(
    PTIME >= 730.5 ~ 1,
    PTIME < 730.5 ~ 0
  ))

df_survival <- df_survival |> 
  mutate(GROUP = case_when(
    TRR_ID_CODE %in% steroid_id_all_vect ~ "Steroids",
    TRR_ID_CODE %in% arm2_ID_vect ~ "Combined",
    TRR_ID_CODE %in% ctrl_id_vect ~ "Control",
    TRUE ~ NA_character_
  )) |> 
  mutate(GROUP = factor(GROUP, levels = c("Steroids", "Combined", "Control")))  # set ONCE, consistently

# Sanity check: make sure nothing got dropped
table(df_survival$GROUP, useNA = "ifany")

# Event indicator based on actual death status, not just PTIME threshold
df_survival <- df_survival |> 
  mutate(event = ifelse(PX_STAT == "D", 1, 0))  # confirm "D" is your death code

## ---- 1-YEAR ----

df_survival_1yr <- df_survival |> 
  mutate(
    event_1yr = ifelse(PTIME <= 365.25, event, 0),
    time_1yr  = pmin(PTIME, 365.25)
  )

fit_1yr <- survfit(Surv(time_1yr, event_1yr) ~ GROUP, data = df_survival_1yr)
summary(fit_1yr)

ggsurvplot(
  fit_1yr,
  data = df_survival_1yr,
  pval = TRUE,
  conf.int = TRUE,
  risk.table = TRUE,
  break.time.by = 90,
  legend.title = "Group",
  legend.labs = c("Steroids", "Combined", "Control"),
  xlab = "Time (days)",
  ylab = "Survival Probability",
  title = "1-Year Kaplan-Meier Survival Curve by Group"
)

summary(fit_1yr, times = 365.25)

df_2groups_1yr <- df_survival_1yr |> 
  filter(GROUP %in% c("Steroids", "Combined")) |> 
  droplevels()  # removes "Control" as an unused factor level

survdiff(Surv(time_1yr, event_1yr) ~ GROUP, data = df_2groups_1yr)

