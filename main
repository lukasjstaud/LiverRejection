# Tables

# Follow Up Anti rejection tables

followup_12m_anti_rej_table <- data.frame(
  AntiRejectionTherapy = str_remove(COLS_TO_CHECK,COL_TAIL),
  Frequency = sapply(df_immuno_fol[COLS_TO_CHECK], function(x) sum(x == 1, na.rm = TRUE))
)

followup_12m_anti_rej_table %>%
  arrange(desc(Frequency)) %>%
  kable(caption = "Frequency of Anti-Rejection Therapies Used At Follow up < 1 year s/p Liver Transplant") %>%
  kable_styling(bootstrap_options = c("striped", "hover", "condensed"))

#-------------------------------------------------------------------------------------
# In patient hospital course sp liver transplant

post_tx_anti_rej_table <- data.frame(
  AntiRejectionTherapy = str_remove(COLS_TO_CHECK,COL_TAIL),
  Frequency = sapply(df_immuno_induc[COLS_TO_CHECK], function(x) sum(x == 1, na.rm = TRUE))
)

post_tx_anti_rej_table %>%
  arrange(desc(Frequency)) %>%
  kable(caption = "Frequency of Anti-Rejection Therapies Used While Admitted s/p Liver Transplant") %>%
  kable_styling(bootstrap_options = c("striped", "hover", "condensed"))
