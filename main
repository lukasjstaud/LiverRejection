  cols_label(
    Variable = "Characteristic",
    Combined = paste0("Combined (n = ", num_rej, ")"),
    Steroid = paste0("Steroid (n = ", num_ctrl, ")"),
    `P value` = "P value"
  ) %>%
  tab_style(
    style = cell_text(weight = "bold"),
    locations = cells_body(rows = demo_tbl4$is_header)
  ) %>%
  tab_style(
    style = cell_text(align = "left"),
    locations = cells_column_labels(columns = Variable)
